{
    "name"                     : "Air",
    "is_dark"                  : false,
    "tooltip"                  : "Air",
    "image_file"               : "icons/theme/theme-air.png",
    "form_background_file"     : "figures/backgrounds/background_grid.png",
    "home_window_logo_image"   : "figures/splash/home_screen_light.png",

    // MOVING TABS
    // ===========
    // The GUI allows to grab a tab by its header and drag it. Then you can drop it on top of
    // another tab, or squeeze it in between two tabs. While dragging the tab, areas are shown
    // where you can drop it. These areas are passive by default, and active when you hover over
    // them with the tab in your hand. We call these areas "dock points".
    "dock_point_color_active"  : "#ff729fcf", // Dock point when hovering over it with a tab in your hand
    "dock_point_color_passive" : "#77729fcf", // Dock point

    // BACKGROUND
    // ==========
    "form_background"    : "#fff0f0f0", // Window background
    "general_background" : "#fff0f0f0", // ?
    "dark_background"    : "#fff2f2f2", // Background for textboxes
    "menubar_background" : "#fff0f0f0", // Backgound for top-level menubar (e.g. "File", "Help", ..)
    "menu_background"    : "#fff0f0f0", // Background for dropdown or pop-out menus under menubar items

    // TOOLTIP
    // =======
    "tool_tip_font"       : "#ffffffff", // Font on tooltip
    "tool_tip_background" : "#ff000000", // Background of tooltip
    "tool_tip_border"     : "#ffffffff", // Border around tooltip

    // SPLITTER
    // ========
    // The GUI has a fine splitter line between adjacent tab bodies
    "splitter_handle_background" : "#fff0f0f0", // Splitter line regular color
    "splitter_handle_hover"      : "#55729fcf", // Splitter line when hovered
    "splitter_handle_pressed"    : "#ff729fcf", // Splitter line when pressed and dragged
                                                // (to enlarge or squeeze the tab body size)

    // PIECES AI
    // =========
    // The user can open 'Pieces AI' in a tab, to chat with the AI. Like any chat application, this
    // tab has two major part: the 'question' part where you can type your question for the AI, and
    // the 'answer' part where the AI displays its replies.
    "pieces_question_background" : "#ffeeeeef", // Background of question textfield
    "pieces_question_border"     : "#ffeeeeef", // Border around question textfield
    "pieces_answer_background"   : "#ffffffff", // Background of answer textfield
    "pieces_answer_border"       : "#ffeeeeef", // Border around answer textfield

    // BUTTONS
    // =======
    "dropdown_border" : "#ffb9cfe8", // Border around dropdown widgets
    "button_border"   : "#ffb9cfe8", // Border around buttons and textfields

    // REGULAR BUTTON & UNCHECKED TOGGLE BUTTON
    "button_unchecked"       : "#fff7f7f7", // Background
    "button_unchecked_hover" : "#ffffffff", // Background when hovered
    "button_unchecked_font"  : "#ff000000", // Font

    // CHECKED TOGGLE BUTTON
    "button_checked"         : "#ffd0d0d0", // Background
    "button_checked_hover"   : "#ffd7d7d7", // Background when hovered
    "button_checked_font"    : "#ff000000", // Font

    // POSITIVE MESSAGE BUTTON (eg. update available)
    "button_good_border"         : "#ff00ff00", // Border
    "button_good_unchecked"      : "#ff73d216", // Background
    "button_good_unchecked_font" : "#ffffffff", // Font
    "button_good_checked_font"   : "#ffffffff", // Font if checked (must be a toggle button)

    // NEGATIVE MESSAGE BUTTON (eg. error or warning detected)
    "button_error_border"           : "#ffff0000", // Border
    "button_error_unchecked"        : "#ffcc0000", // Background
    "button_error_unchecked_font"   : "#ffffffff", // Font
    "button_error_checked_font"     : "#ffffffff", // Font if checked (must be a toggle button)
    "button_warning_border"         : "#ffffff00", // Border
    "button_warning_unchecked"      : "#fff57900", // Background
    "button_warning_unchecked_font" : "#ff000000", // Font
    "button_warning_checked_font"   : "#ff000000", // Font if checked (must be a toggle button)

    // TABLES
    // ======
    // For example: the table in the CREATE PROJECT window
    "table_header" : "#fff7f7f7", // Background table header
    "table_grid"   : "#ffb9cfe8", // Grid lines in table

    // SCROLLBAR
    // =========
    // Long thin track at the edge of a tab body (eg. editor tab) with a movable "handle" which
    // can be dragged to navigate vertically or horizontally through content exceeding the visible
    // area of the tab body.
    "scroll_bar": {
        "background"   : "#fff0f0f0", // Color of the scrollbar track behind the movable handle
        "handle"       : "#ffcdcdcd", // Color of the movable handle
        "handle_hover" : "#ffa6a6a6", // Color of the movable handle when hovered
        "show_arrows"  : false,       // Show arrows at each end of the scrollbar track
        "arrow_up"     : "icons/arrow/chevron/chevron_up.svg",
        "arrow_down"   : "icons/arrow/chevron/chevron_down.svg",
        "arrow_left"   : "icons/arrow/chevron/chevron_left.svg",
        "arrow_right"  : "icons/arrow/chevron/chevron_right.svg"
    },

    // CONSOLE
    // =======
    // The console that executes shell commands for clean, build and flash. The
    // console usually has a black background (regardless of the theme) and
    // white default font. We define some other font colors too (such as red,
    // green, ...) in a way that displays nicely on the black background.
    "console": {
        "background": "#ff000000",
        "border": "#ff2e3436",
        "fonts":
        {
            "default": "#ffffffff",
            "black": "#ff000000",
            "red": "#ffef2929",
            "green": "#ffa1e85b",
            "yellow": "#fffce94f",
            "blue": "#ff8fb3d9",
            "magenta": "#ff8fb3d9",
            "cyan": "#ff8fb3d9",
            "white": "#ffffffff",
            "purple": "#ffc5a4c1",
            "info": "#ffffffff",    // white
            "warning": "#fffce94f", // yellow
            "error": "#ffef2929",   // red
            "sa": "#ff8fb3d9",      // cyan
            "teal": "#ff4ec9b0",
            "path": "#ffc5e478"
        }
    },

    // EDITOR
    // ======
    // -*-*- NOTE ABOUT TEXT SELECTION COLORS IN THE EDITOR -*-*-
    // Text selection coloring in the editor is quite complex. the following three rules apply:
    //
    // 1) When selecting text, the background color is theme["fonts"]["selection"]["background"]
    // (no need to be transparent, it really is a background color) and the text color is set to
    // theme["fonts"]["selection"]["color"].
    //
    // 2) As soon as your selection covers an entire token, the editor puts an extra overlay color
    // on top: theme["indication"]["selection"]. Beware, this is an overlay color, so it must be
    // transparent! This overlay is not only put on the token you selected, but also on all nearby
    // tokens with the same name.
    //
    // 3) Finally, keep in mind that theme["cursor_line_overlay"] color is an extra overlay on top
    // of the current editor line (in which the cursor is located). It is always on the current
    // editor line, regardless of any text being selected there or not.
    //
    // When applying these three rules, you can conclude that the apparent background color of a
    // token you select, is actually a mix of:
    // - theme["fonts"]["selection"]["background"]
    // - theme["indication"]["selection"]
    // - theme["cursor_line_overlay"]
    //
    // The apparent text color is then a mix of:
    // - theme["fonts"]["selection"]["color"]
    // - theme["indication"]["selection"]
    // - theme["cursor_line_overlay"]
    //
    // Applying the three rules on the nearby tokens with the same name, you get an apparent
    // background color as a mix of:
    // - theme["editor_background"]
    // - theme["indication"]["selection"]
    //
    // And the apparent text color of these nearby tokens as a mix of:
    // - theme["fonts"]["selection"]["color"]
    // - theme["indication"]["selection"]
    //
    // -*-*- END OF NOTE -*-*-

    "editor_background"   : "#ffe1ebf4", // Editor background color
    "cursor"              : "#ff000000", // Color of the cursor itself
    "cursor_line_overlay" : "#30729fcf", // Overlay color on text line in which cursor is located.
                                         // Warning: this color is an overlay on the text, so it
                                         // must be transparent!

    "cursor_line_frame" : false, // Decide if you want the previous color from "cursor_line_overlay"
                                // to be used as a thin frame around the line in which the cursor
                                // is located (like VSCode does) or as a background color (actually
                                // an overlay color) that covers the entire line (like JetBrains
                                // does). For a thin frame, enter `true`. For the entire background,
                                // enter `false`.
                                // Note: if you choose for a thin frame, you should make the color
                                // stand out a little more.

    "fold_margin": {               // Fold Margin is currently unused
        "foreground": "#ffffffff", // Text color in fold margin
        "background": "#ffe0e0e0"  // Background color fold margin
    },
    "line_margin": {               // Line Margin shows the code line numbers
        "foreground": "#ff2e3436", // Text color in line margin
        "background": "#ffe1ebf4"  // Background color line margin
    },

    "indication": {
        "highlight" : "#5000ff00", // Overlay color on highlighted text in the editor. Text is
                                   // highlighted when, for example, searching a token with Ctrl+F.
                                   // Warning: This color is an overlay on the text, so it must be
                                   // transparent!

        "selection" : "#40c8c8c8", // See NOTE ABOUT TEXT SELECTION COLORS IN THE EDITOR.

        "replace"   : "#5032b4ff", // Overlay color on replaced text in the editor. Currently there
                                   // is a bug, see https://forum.embeetle.com/t/highlighting-replaced-text-not-working/1017

        "symbol"    : "#ff0000ff", // Text color given to a token that is recognized as a C/C++
                                   // symbol when you hover over it with the mouse.

        "error"     : "#ffff0000", // Text color in debugger console for error messages. Also used
                                   // as background color in the editor when flashing a line that
                                   // contains an error. If used as background color, it's a true
                                   // background color - not an overlay. So it can be opaque.

        "warning"   : "#ffedd400", // Same as previous, but for warnings instead of errors.

        "hover"     : "#ffd8eaf9", // Used as a temporary background color for a myriad of user
                                   // interface elements while the mouse hovers over them. For
                                   // example: items in the Filetree, Dashboard, ...

        "background_selection" : "#64c8c8c8" // Overlay color on all unselected text in the editor
                                             // when you do a search operation on selected text.
                                             // This overlay color must be transparent and intends
                                             // to grey out the non-relevant text during the search
                                             // (make it somewhat less visible).
                                             // Note: we have a bug in the implementation for
                                             // 'search in selection':
                                             // https://forum.embeetle.com/t/issue-in-editor-search-in-selection-functionality/1019
    },
    "text_differ": {
        "indicator_unique_1_color": "#50ff9fcf", // Background color for all text that is unique to
                                                 // to the original document (so must be removed).
                                                 // Usually this color is a bit red and is preceded
                                                 // by a red `-` sign in the margin.

        "indicator_unique_2_color": "#50ad7fa8", // Background color for all text that is unique to
                                                 // the new document (so it must be added). Usually
                                                 // this color is a bit green and is preceded by a
                                                 // green `+` sign in the margin.

        "indicator_similar_color" : "#508ae234"  // Background color for all text that is almost
                                                 // similar between both documents. Usually this
                                                 // color is a bit blue and is preceded by a blue
                                                 // `=` sign in the margin.
    },
    "tab_headers": {
        // Standard (not indicated) tab header. 'Not indicated' means that the user is NOT working
        // in the encapsulating tab widget, the focus is on another one (by 'tab widget' I mean the
        // widget that contains all the tabs, side-by-side, and their bodies).
        "standard": {
            // The tab header that is showing its body (index matches). Even though the body is
            // shown, keep in mind that the user is now working in some tab body in another tab
            // widget! Hence 'not indicated'.
            "current_index": {
                "color"      : "#ff000000", // Text color
                "background" : "#ffadc5e6", // Background color
                "border"     : "#ff3c72bb"  // Border
            },
            // A tab header not showing its body (index doesn't match).
            "other_index": {
                "color"      : "#ff000000", // Text color
                "background" : "#ffb9cfe8", // Background color
                "border"     : "#ff3c72bb"  // Border
            }
        },

        // Standard indicated tab header. 'Indicated' means that the user is working right now in
        // a tab body inside the encapsulating tab widget.
        "standard_indicated": {
            // The user is working right now in the body that belongs to this tab header.
            "current_index": {
                "color"      : "#ffffffff", // Text color
                "background" : "#ff3c72bb", // Background color
                "border"     : "#ff3c72bb"  // Border
            },
            // A tab header not showing its body (index doesn't match).
            "other_index": {
                "color"      : "blue",     // Text color
                "background" : "blue",     // Background color
                "border"     : "#ff3c72bb" // Border
            }
        },

        // Tab header from a file, opened in the editor, that is inside the compiler toolchain.
        "inside_compiler": {
            "current_index": {
                "color"      : "#ff173560", // Text color
                "background" : "#ffa4c1e0", // Background color
                "border"     : "#ff3c72bb"  // Border
            },
            "other_index": {
                "color"      : "#ff204a87", // Text color
                "background" : "#ffbfd3e9", // Background color
                "border"     : "#ff3c72bb"  // Border
            }
        },

        // Tab header from a file, opened in the editor, that is excluded from the project.
        "excluded_from_project": {
            "current_index": {
                "color"      : "#ff660000", // Text color
                "background" : "#fffaa7a7", // Background color
                "border"     : "#ff3c72bb"  // Border
            },
            "other_index": {
                "color"      : "#ffa40000", // Text color
                "background" : "#fffddbdb", // Background color
                "border"     : "#ff3c72bb"  // Border
            }
        },

        // Tab header from a file, opened in the editor, that is outside the project folder.
        "outside_project": {
            "current_index": {
                "color"      : "#ffffffff", // Text color
                "background" : "#ff5c3566", // Background color
                "border"     : "#ff3c72bb"  // Border
            },
            "other_index": {
                "color"      : "#ff204a87", // Text color
                "background" : "#ffad7fa8", // Background color
                "border"     : "#ff3c72bb"  // Border
            }
        },

        // The close button on the right side of the tab header. Usually a cross. Clicking this
        // button closes the tab.
        "close_button": {
            "passive": {
                "standard" : "icons/tab/close.png",
                "hover"    : "icons/tab/close_hover.png",
                "press"    : "icons/tab/close_press.png"
            },
            "active": {
                "standard" : "icons/tab/close_white.png",
                "hover"    : "icons/tab/close_white_hover.png",
                "press"    : "icons/tab/close_white_press.png"
            }
        }
    },

    // SHADE
    // Each theme has its own 'theme color' which is prominent throughout the theme. For example:
    //   - air      => light blue
    //   - crystal  => light grey
    //   - graphite => black
    //   - obsidian => black (but deeper)
    //   - water    => dark blue
    //
    // The `shade` list starts from white (or black for a dark theme) and makes its way to a dark
    // color (or white color for a dark theme), thereby passing through the 'theme color' on the
    // way.
    // The colors in this list are then used from time to time in the user interface.
    "shade": [
        "#ffffffff",
        "#fff9fbfd",
        "#ffecf2f9",
        "#ffe1ebf4",
        "#ffd5e1f0",
        "#ffc8d9ec",
        "#ffb9cfe8",
        "#ffacc7e3",
        "#ff9ebdde",
        "#ff85abd6",
        "#ff729fcf",
        "#ff6391cd",
        "#ff5184c8",
        "#ff4379c2",
        "#ff3c72bb",
        "#ff376aae",
        "#ff3465a4"
    ],
