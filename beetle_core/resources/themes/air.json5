        "node_closed_middle"              : "icons/treeview/node-closed-middle.png",
        "node_closed_last"                : "icons/treeview/node-closed-last.png",
        "node_open_only"                  : "icons/treeview/node-open-only.png",
        "node_open_middle"                : "icons/treeview/node-open-middle.png",
        "node_open_last"                  : "icons/treeview/node-open-last.png",
        "t"                               : "icons/arrow/spacer/TSpacer.png",
        "t-add"                           : "icons/arrow/spacer/TSpacer_ad.png",
        "l"                               : "icons/arrow/spacer/LSpacer.png",
        "l-add"                           : "icons/arrow/spacer/LSpacer_ad.png",
        "line"                            : "icons/arrow/spacer/ISpacer.png",
        "expand_arrow"                    : "icons/arrow/spacer/arrow.png"
