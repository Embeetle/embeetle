          <fields>
            <field>
              <name>ERRWFLG</name>
              <displayName>Error Warning Flag</displayName>
              <description>Indicates that the CAN controller has reached the error warning level (RX or TX error counter ≥ 96).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_WARNING</name>
