        <register>
          <name>RXF0</name>
          <displayName>CAN Receive FIFO 0 Register</displayName>
          <description>
            Reflects the current state of FIFO0, including the number of messages stored,
            full/overrun flags, and the release output mailbox control.
          </description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>FMNUM0</name>
              <displayName>FIFO0 Message Number</displayName>
              <description>
                Reflects the number of messages currently stored in FIFO0 (0..3).
                Each time a new message is received, this count increases until 3,
                and it decreases by 1 when the software releases a message from FIFO0.
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ZERO_MESSAGES</name>
                  <displayName>0 Messages</displayName>
                  <description>FIFO0 is empty.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ONE_MESSAGE</name>
                  <displayName>1 Message</displayName>
                  <description>FIFO0 contains 1 message.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TWO_MESSAGES</name>
                  <displayName>2 Messages</displayName>
                  <description>FIFO0 contains 2 messages.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>THREE_MESSAGES</name>
                  <displayName>3 Messages</displayName>
                  <description>FIFO0 contains 3 messages (full).</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Read at runtime to see how many messages are queued in FIFO0.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FFULLFLG0</name>
              <displayName>FIFO0 Full Flag</displayName>
              <description>
                Set by hardware when FIFO0 contains three messages. Cleared by software
                writing 1.
              </description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOT_FULL</name>
                  <displayName>Not Full</displayName>
                  <description>FIFO0 is not full.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FULL</name>
                  <displayName>Full</displayName>
                  <description>FIFO0 contains 3 messages.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically cleared by writing 1 after processing messages to allow receiving new ones.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FOVRFLG0</name>
              <displayName>FIFO0 Overrun Flag</displayName>
              <description>
                Set by hardware when a new message arrives while FIFO0 is full. Cleared by
                software writing 1.
              </description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRUN</name>
                  <displayName>No Overrun</displayName>
                  <description>No overrun has occurred or flag is cleared.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OVERRUN_OCCURRED</name>
                  <displayName>Overrun Occurred</displayName>
                  <description>FIFO0 received a new message while already full.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically cleared by writing 1 after handling the overrun condition.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RFOM0</name>
              <displayName>Release FIFO0 Output Mailbox</displayName>
              <description>
                If 1, releases the output mailbox of FIFO0, allowing the next stored message
                to be accessed. Hardware clears this bit to 0 after the release.
              </description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_RELEASE</name>
                  <displayName>No Release</displayName>
                  <description>Output mailbox is not released.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RELEASE</name>
                  <displayName>Release Mailbox</displayName>
                  <description>Frees FIFO0 output mailbox to access next message.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Software writes 1 after reading the top message to advance the FIFO.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
