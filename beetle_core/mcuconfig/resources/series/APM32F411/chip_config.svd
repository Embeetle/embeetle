              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically configured in initialization to enable or disable FIFO0 message pending interrupts.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FFULLIEN0</name>
              <displayName>FIFO0 Full Interrupt Enable</displayName>
