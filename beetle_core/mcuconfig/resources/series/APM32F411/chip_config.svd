            </field>
            <field>
              <name>REGEXTTRGEN</name>
              <displayName>Regular External Trigger Enable</displayName>
              <description>
                Enables or disables the detection edge for the external trigger on 
                regular channels. 00 = disabled, 01 = rising edge, 10 = falling edge, 
                11 = both edges.
              </description>
              <bitOffset>28</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <displayName>Trigger Disabled</displayName>
                  <description>No external trigger detection for regular channels.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RISING</name>
                  <displayName>Rising Edge Trigger</displayName>
                  <description>Trigger on rising edge of selected external signal.</description>
