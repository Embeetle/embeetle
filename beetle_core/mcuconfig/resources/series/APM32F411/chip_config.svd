                  <description>Silent mode disabled (normal operation)</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Silent (mute) mode enabled</description>
                  <value>1</value>
