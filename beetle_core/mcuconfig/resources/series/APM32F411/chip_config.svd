                <enumeratedValue>
                  <name>2_STOP</name>
                  <description>2 stop bits</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>1_5_STOP</name>
                  <description>1.5 stop bits</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>LINMEN</name>
              <displayName>LIN Mode Enable</displayName>
