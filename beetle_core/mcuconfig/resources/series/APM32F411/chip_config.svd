            <field>
              <name>SCNACKEN</name>
              <displayName>NACK Transmit Enable in Smartcard Mode</displayName>
              <description>NACK Transmit Enable During Parity Error in Smartcard Function (This bit does not exist on UART4 or UART5).</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_NACK</name>
                  <description>Do not transmit NACK on parity error</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NACK_ON_ERROR</name>
                  <description>Transmit NACK on parity error</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>SCEN</name>
              <displayName>Smartcard Mode Enable</displayName>
              <description>SCEN bit of USART_CTRL3 register decides whether to enter the smart card mode (This bit does not exist on UART4 or UART5).</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>Smartcard mode disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Smartcard mode enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>DMARXEN</name>
              <displayName>DMA Receive Enable</displayName>
              <description>DMA Receive Enable (This bit does not exist on UART4 or UART5).</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>DMA receiver disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>DMA receiver enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>DMATXEN</name>
              <displayName>DMA Transmit Enable</displayName>
              <description>DMA Transmit Enable (This bit does not exist on UART4 or UART5).</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>DMA transmitter disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>DMA transmitter enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>RTSEN</name>
              <displayName>RTS Hardware Flow Control Enable</displayName>
              <description>RTS Hardware Flow Control Function Enable. RTS: 'Request To Send', which is an output signal indicating readiness to receive. This request to receive data is only made when there is space in the receive buffer: when data can be received, the RTS output is pulled to low. (This bit does not exist on UART4 or UART5).</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>RTS flow control disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>RTS flow control enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>CTSEN</name>
              <displayName>CTS Hardware Flow Control Enable</displayName>
              <description>CTS Hardware Flow Control Function Enable. CTS: 'Clear To Send', which is an input signal. Only when CTS input signal is low, the data can be transmitted; otherwise, the data cannot be transmitted. If CTS signal is pulled high during data transmission, the data transmission will be stopped after completion. If write operation is performed for the data register when CTS is high, the data will not be transmitted until CTS is valid. (This bit does not exist on UART4 or UART5).</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>CTS flow control disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>CTS flow control enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>CTSIEN</name>
              <displayName>CTS Interrupt Enable</displayName>
              <description>CTS Interrupt Enable: An interrupt will be generated when CTSFLG is set. (This bit does not exist on UART4 or UART5).</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>CTS interrupt disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>CTS interrupt enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>SAMCFG</name>
              <displayName>Sample Method Configure</displayName>
              <description>Sample Method Configure. This bit can be set only when USART is not enabled.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>THREE_SAMPLE</name>
                  <description>Sampling for three times</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SINGLE_SAMPLE</name>
                  <description>Single sampling; flag of noise detection disabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <displayName>DATA</displayName>
          <description>Data register</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>DATA</name>
              <displayName>Data Value</displayName>
              <description>Transmit or receive data value. - Reading this register returns the received data. - Writing to this register sends data. If parity is enabled and using 9 data bits, bit 8 is the parity bit. If parity is enabled and using 8 data bits, bit 7 is the parity bit.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>9</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>GTPSC</name>
          <displayName>GTPSC</displayName>
          <description>Guard time and prescaler register. Cannot be used for UART4 and UART5.</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>PSC</name>
              <displayName>Prescaler Factor</displayName>
              <description>Divides the system clock to provide the clock for IR or Smart Card mode. - In IR low-power mode, PSC[7:0] can be 1..255 (0 is reserved). - In IR normal mode, PSC must be 1. - In Smart Card mode, PSC[4:0] is significant (0 is reserved; a nonzero value corresponds to 2x(PSC[4:0]) prescaler, e.g. 1 =&gt; 2, 2 =&gt; 4, etc.).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>GRDT</name>
              <displayName>Guard Time Value</displayName>
              <description>Sets the guard time (in baud clock cycles). In Smart Card mode, this delays TXCFLG until the guard time finishes. 0 means no additional guard time; up to 255 for the maximum delay.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>STS</name>
          <displayName>STS</displayName>
          <description>Status register</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0xC0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>PEFLG</name>
              <displayName>Parity Error Flag</displayName>
              <description>Set by hardware in receive mode when a parity error is detected. Clear by software, after setting of RXBNEFLG, first read USART_STS and then read USART_DATA.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_PARITY_ERROR</name>
                  <description>No parity error</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PARITY_ERROR</name>
                  <description>Parity check error occurred</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>FEFLG</name>
              <displayName>Frame Error Flag</displayName>
              <description>Set by hardware if stop bit is missing, too much noise, or on break symbol. Cleared by reading USART_STS and then reading USART_DATA.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_FRAME_ERROR</name>
                  <description>No frame error</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FRAME_ERROR</name>
                  <description>Frame error or break detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>NEFLG</name>
              <displayName>Noise Error Flag</displayName>
              <description>Set by hardware when noise is detected during reception. Cleared by reading USART_STS and then reading USART_DATA.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_NOISE_ERROR</name>
                  <description>No noise error</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOISE_ERROR</name>
                  <description>Noise error detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>OVREFLG</name>
              <displayName>Overrun Error Flag</displayName>
              <description>Set by hardware when new data arrives while RXBNEFLG=1 (which means the receive data buffer is full). Cleared by reading USART_STS and then reading USART_DATA.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRUN</name>
                  <description>No overrun error</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OVERRUN_ERROR</name>
                  <description>Overrun error occurred</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>IDLEFLG</name>
              <displayName>Idle Line Detected Flag</displayName>
              <description>Set by hardware when an idle bus is detected. Cleared by reading USART_STS and then reading USART_DATA.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_IDLE_LINE</name>
                  <description>No idle line detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_DETECTED</name>
                  <description>Idle line detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>RXBNEFLG</name>
              <displayName>Receive Buffer Not Empty Flag</displayName>
              <description>Set by hardware when data is transferred from shift register to DATA. Cleared by reading DATA or by writing 0 to this bit.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BUFFER_EMPTY</name>
                  <description>Receive buffer empty</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER_NOT_EMPTY</name>
                  <description>Receive buffer contains data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>TXCFLG</name>
              <displayName>Transmission Complete Flag</displayName>
              <description>Set by hardware after the last frame is transmitted and TXBEFLG=1 (which means the Transmit Buffer is empty). Cleared by reading USART_STS, then writing 0 to this bit, or by writing DATA.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOT_COMPLETE</name>
                  <description>Transmission not complete</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>COMPLETE</name>
                  <description>Last frame transmission complete</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEFLG</name>
              <displayName>Transmit Buffer Empty Flag</displayName>
              <description>Set by hardware when the shift register has loaded data from DATA register. Cleared by writing to DATA register.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BUFFER_NOT_EMPTY</name>
                  <description>TX buffer not empty</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUFFER_EMPTY</name>
                  <description>TX buffer empty</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>LBDFLG</name>
              <displayName>LIN Break Detected Flag</displayName>
              <description>Set by hardware when a LIN break is detected. Cleared by writing 0 to this bit.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_LIN_BREAK</name>
                  <description>No LIN break detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LIN_BREAK_DETECTED</name>
                  <description>LIN break detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>CTSFLG</name>
              <displayName>CTS Change Flag</displayName>
              <description>Set by hardware when CTS flow control is enabled (see CTSEN bitfield from CTRL3 register) and the nCTS pin toggles. Cleared by writing 0 to this bit.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_CHANGE</name>
                  <description>No change in CTS line</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CTS_CHANGED</name>
                  <description>CTS line changed</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>USART3</name>
      <description>Universal synchronous asynchronous receiver transmitter</description>
      <groupName>USART</groupName>
      <baseAddress>0x40004800</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
        <protection>n</protection>
      </addressBlock>
      <interrupt>
        <name>USART3</name>
        <description>USART3 global interrupt</description>
        <value>39</value>
      </interrupt>
      <registers>
        <register>
          <name>BR</name>
          <displayName>BR</displayName>
          <description>Baud rate register</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>FBR</name>
              <description>fraction of USARTDIV</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>IBR</name>
              <description>mantissa of USARTDIV</description>
              <bitOffset>4</bitOffset>
              <bitWidth>12</bitWidth>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <displayName>CTRL1</displayName>
          <description>Control Register 1</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>TXBF</name>
              <displayName>Transmit Break Frame</displayName>
              <description>This bit can be set by software and cleared to 0 by hardware when the stop bit of the break frame is transmitted.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOT_TRANSMIT</name>
                  <description>Break frame not transmitted</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TRANSMIT</name>
                  <description>Break frame will be transmitted</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>RXMUTEEN</name>
              <displayName>Receiver Mute Enable</displayName>
              <description>Enables or disables the USART receiver in mute mode.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>Mute mode disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Mute mode enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>RXEN</name>
              <displayName>Receiver Enable</displayName>
              <description>Enables or disables the USART receiver. The receiver can be disabled during low-power sleep modes.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>Receiver disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Receiver enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>TXEN</name>
              <displayName>Transmitter Enable</displayName>
              <description>Enables or disables the USART transmitter. The transmitter is used to send data.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>Transmitter disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Transmitter enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>IDLEIEN</name>
              <displayName>IDLE Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the IDLE line is detected.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>IDLE interrupt disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>IDLE interrupt enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>RXBNEIEN</name>
              <displayName>RX Buffer Not Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the RX buffer is not empty.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>Interrupt disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Interrupt enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
