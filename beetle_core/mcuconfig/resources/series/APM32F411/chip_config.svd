              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <displayName>Disabled</displayName>
                  <description>Interrupt generation disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <displayName>Enabled</displayName>
                  <description>Interrupt generation enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically configured in initialization to enable or disable FIFO0 full interrupts.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FOVRIEN0</name>
              <displayName>FIFO0 Overrun Interrupt Enable</displayName>
              <description>When set, generating an interrupt if FIFO0 receives a new message while already full.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <displayName>Disabled</displayName>
                  <description>Interrupt generation disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <displayName>Enabled</displayName>
                  <description>Interrupt generation enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically configured in initialization to enable or disable FIFO0 overrun interrupts.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FMIEN1</name>
              <displayName>FIFO1 Message Pending Interrupt Enable</displayName>
              <description>When set, generating an interrupt when the number of messages in FIFO1 becomes nonzero.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <displayName>Disabled</displayName>
                  <description>Interrupt generation disabled.</description>
                  <value>0</value>
