                  <name>LEN_4</name>
                  <displayName>Data Length 4</displayName>
                  <description>Frame has 4 data bytes.</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEN_5</name>
                  <displayName>Data Length 5</displayName>
                  <description>Frame has 5 data bytes.</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
