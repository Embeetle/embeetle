              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEN_0</name>
                  <displayName>Data Length 0</displayName>
                  <description>Frame has 0 data bytes.</description>
                  <value>0</value>
                </enumeratedValue>
