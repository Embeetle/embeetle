        <register>
          <name>WRTTIM4</name>
          <displayName>WRTTIM4</displayName>
          <description>SRAM/NOR-Flash write timing registers 4</description>
          <addressOffset>0x11C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0xFFFFFFF</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>ADDRSETCFG</name>
              <description>Address Setup Time Configure</description>
              <bitOffset>0</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ADDRHLDCFG</name>
              <description>Address-Hold Time Configure</description>
              <bitOffset>4</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>DATASETCFG</name>
              <description>Data-Setup Time Configure</description>
              <bitOffset>8</bitOffset>
              <bitWidth>8</bitWidth>
            </field>
            <field>
              <name>BUSTURNCFG</name>
              <description>Bus Turnaround Phase Duration Configure</description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
            </field>
            <field>
              <name>ASYNCACCCFG</name>
