              </vendorExtensions>
            </field>
            <field>
              <name>LOWESTP0</name>
              <displayName>Lowest Priority Flag Mailbox 0</displayName>
              <description>Indicates mailbox 0 is the lowest priority among mailboxes waiting to transmit (only relevant when multiple mailboxes are pending).</description>
              <bitOffset>29</bitOffset>
