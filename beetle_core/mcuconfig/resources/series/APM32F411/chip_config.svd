        <register>
          <name>INJDATA1</name>
          <displayName>ADC Injected Data Register 1</displayName>
          <description>
            Holds the converted data of the injected channel(s). Only the lower 16 bits
            are used to store the conversion result; the upper 16 bits are reserved.
          </description>
          <addressOffset>0x3C</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>INJDATA</name>
              <displayName>Injected Data</displayName>
              <description>
                Conversion result of the injected channel. Bits [15:0] hold the valid
                data, while the upper 16 bits are reserved.
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Read at runtime to obtain the most recent injected channel
                  conversion result.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
