            <field>
              <name>REGSEQC10</name>
              <displayName>10th Conversion Channel</displayName>
              <description>
                Channel number for the 10th conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>15</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured to select which channel is converted 10th 
                  in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGSEQC11</name>
              <displayName>11th Conversion Channel</displayName>
              <description>
                Channel number for the 11th conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>20</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured to select which channel is converted 11th 
                  in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGSEQC12</name>
              <displayName>12th Conversion Channel</displayName>
              <description>
                Channel number for the 12th conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>25</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured to select which channel is converted 12th 
                  in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>REGSEQ3</name>
          <displayName>ADC Regular Sequence Register 3</displayName>
          <description>
            Configures the 1ˢᵗ to 6ᵗʰ channels in the regular conversion sequence.
          </description>
          <addressOffset>0x34</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>REGSEQC1</name>
              <displayName>1st Conversion Channel</displayName>
              <description>
                Channel number for the 1st conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set which channel is converted 1st in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGSEQC2</name>
              <displayName>2nd Conversion Channel</displayName>
              <description>
                Channel number for the 2nd conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>5</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set which channel is converted 2nd in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGSEQC3</name>
              <displayName>3rd Conversion Channel</displayName>
              <description>
                Channel number for the 3rd conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>10</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set which channel is converted 3rd in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGSEQC4</name>
              <displayName>4th Conversion Channel</displayName>
              <description>
                Channel number for the 4th conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>15</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set which channel is converted 4th in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGSEQC5</name>
              <displayName>5th Conversion Channel</displayName>
              <description>
                Channel number for the 5th conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>20</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set which channel is converted 5th in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGSEQC6</name>
              <displayName>6th Conversion Channel</displayName>
              <description>
                Channel number for the 6th conversion in the regular sequence.
                Valid range: 0-17.
              </description>
              <bitOffset>25</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set which channel is converted 6th in the regular sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>SMPTIM1</name>
          <displayName>ADC Sampling Time Register 1</displayName>
          <description>
            Configures the sample times for ADC channels 0 to 9. Each channel is assigned
            a 3-bit field, indicating the number of ADC clock cycles used for sampling.
          </description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>SMPCYCCFG1</name>
              <displayName>Sample Time Configuration 1</displayName>
              <description>
                SMPCYCCFG1 covers multiple channels (channels 0..9, 3 bits each = 30 bits),
                but here it's only 27 bits in total. The chapter indicates 8 or 10 channels
                per register, etc. This is a summary of possible arrangement.
                SMPCYCCFG1 holds the sample time configurations (3 bits per channel) for
                multiple ADC channels. Each 3-bit field defines the number of cycles for
                sampling:
                000 = 3 cycles,
                001 = 15 cycles,
                010 = 28 cycles,
                011 = 56 cycles,
                100 = 84 cycles,
                101 = 112 cycles,
                110 = 144 cycles,
                111 = 480 cycles.
                Note: Only 27 bits are used here (9 channels x 3 bits).
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>27</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically set during initialization to configure each channel's
                  sampling time for channels covered by SMPTIM1.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>SMPTIM2</name>
          <displayName>ADC Sampling Time Register 2</displayName>
          <description>
            Configures the sample times for additional ADC channels (e.g. 10 to 17). Each
            channel is assigned a 3-bit field, indicating the number of ADC clock cycles
            used for sampling.
          </description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <!--  -->
            <field>
              <name>SMPCYCCFG2</name>
              <displayName>Sample Time Configuration 2</displayName>
              <description>
                SMPCYCCFG2 covers more channels with 3 bits each. According to the chapter,
                30 bits might be enough for 10 channels.
                SMPCYCCFG2 holds the sample time configurations (3 bits per channel) for
                additional ADC channels. Each 3-bit field defines the number of cycles for
                sampling:
                000 = 3 cycles,
                001 = 15 cycles,
                010 = 28 cycles,
                011 = 56 cycles,
                100 = 84 cycles,
                101 = 112 cycles,
                110 = 144 cycles,
                111 = 480 cycles.
                Note: 30 bits used here (10 channels x 3 bits).
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>30</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically set during initialization to configure each channel's
                  sampling time for channels covered by SMPTIM2.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>STS</name>
          <displayName>ADC Status Register</displayName>
          <description>
            Reports various ADC status flags such as analog watchdog event, end of
            conversion for both regular and injected channels, start flags, and
            overrun detection.
          </description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>AWDFLG</name>
              <displayName>Analog Watchdog Flag</displayName>
              <description>
                Indicates whether an analog watchdog event has occurred (voltage out
                of the configured thresholds).
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Cleared by software after handling the watchdog event.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>EOCFLG</name>
              <displayName>End of Conversion Flag (Regular)</displayName>
              <description>
                Indicates whether a regular channel conversion has completed.
              </description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically cleared by reading the ADC data register or by
                  software in the ISR.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJEOCFLG</name>
              <displayName>End of Conversion Flag (Injected)</displayName>
              <description>
                Indicates whether an injected channel conversion has completed.
              </description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically cleared by reading the injected data registers or
                  by software in the ISR.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJCSFLG</name>
              <displayName>Injected Channel Start Flag</displayName>
              <description>
                Indicates whether an injected channel conversion has started.
              </description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Can be used to monitor if the ADC began injected channel conversion.
                  Cleared by hardware when the conversion ends or by software.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGCSFLG</name>
              <displayName>Regular Channel Start Flag</displayName>
              <description>
                Indicates whether a regular channel conversion has started.
              </description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Can be used to monitor if the ADC began regular channel conversion.
                  Cleared by hardware when the conversion ends or by software.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>OVRFLG</name>
              <displayName>Overrun Flag</displayName>
              <description>
                Indicates an overrun event occurred (new data overwritten before
                previous data was read).
              </description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically cleared by software after acknowledging the overrun.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>ADC2</name>
      <description>Analog-to-digital converter</description>
      <groupName>ADC</groupName>
      <baseAddress>0x40012400</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
        <protection>n</protection>
      </addressBlock>
      <registers>
        <register>
          <name>AWDHT</name>
          <displayName>Analog Watchdog High-Threshold Register</displayName>
          <description>Analog watchdog high-threshold register used to define the upper voltage threshold for monitoring analog input signals.</description>
          <addressOffset>0x24</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0xFFF</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>AWDHT</name>
              <displayName>Analog Watchdog High Threshold</displayName>
              <description>Specifies the high voltage threshold for the analog watchdog. When the ADC input signal exceeds this threshold, an analog watchdog event is triggered.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  This is a configuration field that defines the high threshold for the
                  analog watchdog. It is set during initialization to establish the
                  monitoring limits.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>AWDLT</name>
          <displayName>Analog Watchdog Low-Threshold Register</displayName>
          <description>Analog watchdog low-threshold register used to define the lower voltage threshold for monitoring analog input signals.</description>
          <addressOffset>0x28</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>AWDLT</name>
              <displayName>Analog Watchdog Low Threshold</displayName>
              <description>
                Specifies the low voltage threshold for the analog watchdog. When the
                ADC input signal drops below this threshold, an analog watchdog event
                is triggered.
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>12</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  This is a configuration field that defines the low threshold for the
                  analog watchdog. It is set during initialization to establish the
                  monitoring limits.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <displayName>ADC Control Register 1</displayName>
          <description>
            ADC control register 1. Configures the analog watchdog channel selection, 
            various interrupts, scan mode, discontinuous mode, resolution, and other 
            important ADC operating parameters.
          </description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>AWDCHSEL</name>
              <displayName>Analog Watchdog Channel Select</displayName>
              <description>
                Selects the ADC channel to be monitored by the analog watchdog.
                Valid values range from 0 to 16. Other values are reserved.
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>CH0</name>
                  <displayName>Channel 0</displayName>
                  <description>Monitor ADC analog input channel 0.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH1</name>
                  <displayName>Channel 1</displayName>
                  <description>Monitor ADC analog input channel 1.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH2</name>
                  <displayName>Channel 2</displayName>
                  <description>Monitor ADC analog input channel 2.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH3</name>
                  <displayName>Channel 3</displayName>
                  <description>Monitor ADC analog input channel 3.</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH4</name>
                  <displayName>Channel 4</displayName>
                  <description>Monitor ADC analog input channel 4.</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH5</name>
                  <displayName>Channel 5</displayName>
                  <description>Monitor ADC analog input channel 5.</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH6</name>
                  <displayName>Channel 6</displayName>
                  <description>Monitor ADC analog input channel 6.</description>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH7</name>
                  <displayName>Channel 7</displayName>
                  <description>Monitor ADC analog input channel 7.</description>
                  <value>7</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH8</name>
                  <displayName>Channel 8</displayName>
                  <description>Monitor ADC analog input channel 8.</description>
                  <value>8</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH9</name>
                  <displayName>Channel 9</displayName>
                  <description>Monitor ADC analog input channel 9.</description>
                  <value>9</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH10</name>
                  <displayName>Channel 10</displayName>
                  <description>Monitor ADC analog input channel 10.</description>
                  <value>10</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH11</name>
                  <displayName>Channel 11</displayName>
                  <description>Monitor ADC analog input channel 11.</description>
                  <value>11</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH12</name>
                  <displayName>Channel 12</displayName>
                  <description>Monitor ADC analog input channel 12.</description>
                  <value>12</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH13</name>
                  <displayName>Channel 13</displayName>
                  <description>Monitor ADC analog input channel 13.</description>
                  <value>13</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH14</name>
                  <displayName>Channel 14</displayName>
                  <description>Monitor ADC analog input channel 14.</description>
                  <value>14</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH15</name>
                  <displayName>Channel 15</displayName>
                  <description>Monitor ADC analog input channel 15.</description>
                  <value>15</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CH16</name>
                  <displayName>Channel 16</displayName>
                  <description>Monitor ADC analog input channel 16.</description>
                  <value>16</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  This field is typically set during initialization to configure which
                  channel is monitored by the ADC's analog watchdog.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>EOCIEN</name>
              <displayName>End-of-Conversion Interrupt Enable</displayName>
              <description>
                Enables or disables the interrupt when a regular channel conversion is 
                complete.
              </description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Interrupt Disabled</displayName>
                  <description>EOC interrupt is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Interrupt Enabled</displayName>
                  <description>EOC interrupt is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically set during initialization to enable or disable the EOC 
                  interrupt.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>AWDIEN</name>
              <displayName>Analog Watchdog Interrupt Enable</displayName>
              <description>
                Enables or disables the interrupt when the analog watchdog detects that 
                the input signal has crossed the threshold boundaries.
              </description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Interrupt Disabled</displayName>
                  <description>Watchdog interrupt is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Interrupt Enabled</displayName>
                  <description>Watchdog interrupt is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured during initialization if analog watchdog events should
                  trigger an interrupt.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJEOCIEN</name>
              <displayName>Injected End-of-Conversion Interrupt Enable</displayName>
              <description>
                Enables or disables the interrupt when an injected channel conversion 
                completes.
              </description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Interrupt Disabled</displayName>
                  <description>Injected EOC interrupt is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Interrupt Enabled</displayName>
                  <description>Injected EOC interrupt is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically enabled if the application needs to handle injected channel
                  conversions via interrupt.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SCANEN</name>
              <displayName>Scan Mode Enable</displayName>
              <description>
                Enables or disables scan mode for regular or injected channel sequences.
              </description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Scan Mode Disabled</displayName>
                  <description>Single channel or single conversion mode operation.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Scan Mode Enabled</displayName>
                  <description>Scans through multiple channels in a sequence.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured during initialization to specify whether multiple channels
                  should be converted in a sequence.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>AWDSGLEN</name>
              <displayName>Watchdog Single Channel Enable in Scan Mode</displayName>
              <description>
                When set, the analog watchdog monitors only a single channel (selected by 
                AWDCHSEL) in scan mode. Otherwise, it monitors all channels in the scan.
              </description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ALLCHANNELS</name>
                  <displayName>All Channels</displayName>
                  <description>Analog watchdog monitors all channels in scan mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SINGLECHANNEL</name>
                  <displayName>Single Channel</displayName>
                  <description>
                    Analog watchdog monitors only the channel defined by AWDCHSEL.
                  </description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set during initialization if only one channel is to be monitored by
                  the watchdog in scan mode.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJGACEN</name>
              <displayName>Automatic Injected Group Conversion Enable</displayName>
              <description>
                When set, the ADC automatically starts the injected group conversion
                after the regular group conversion completes.
              </description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Disable Auto Injected Conversion</displayName>
                  <description>Injected group conversions are triggered manually or by an external source.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Enable Auto Injected Conversion</displayName>
                  <description>Automatic injected conversion starts after a regular conversion sequence completes.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured if the system design requires automatic injection after 
                  regular conversions.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGDISCEN</name>
              <displayName>Discontinuous Mode on Regular Channels Enable</displayName>
              <description>
                Enables or disables discontinuous mode on the regular channel sequence.
              </description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Disable Discontinuous Mode</displayName>
                  <description>Regular channels operate in normal (continuous or single) scan mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Enable Discontinuous Mode</displayName>
                  <description>Regular channels are converted in smaller sub-groups triggered each time.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set when the application requires partial (sub-group) conversions of 
                  the regular channels, rather than one full sequence at once.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJDISCEN</name>
              <displayName>Discontinuous Mode on Injected Channels Enable</displayName>
              <description>
                Enables or disables discontinuous mode on the injected channel sequence.
              </description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Disable Discontinuous Mode</displayName>
                  <description>Injected channels operate in normal (full) injected scan mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Enable Discontinuous Mode</displayName>
                  <description>Injected channels are converted in smaller sub-groups triggered each time.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set when the application needs partial (sub-group) conversions of 
                  the injected channels.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DISCNUMCFG</name>
              <displayName>Discontinuous Mode Channel Count</displayName>
              <description>
                Specifies the number of channels in each discontinuous group for regular 
                channel conversions. 000 = 1 channel, 001 = 2 channels, ... 111 = 8 channels.
              </description>
              <bitOffset>13</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ONE</name>
                  <displayName>1 Channel</displayName>
                  <description>Each sub-group conversion has 1 channel.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TWO</name>
                  <displayName>2 Channels</displayName>
                  <description>Each sub-group conversion has 2 channels.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>THREE</name>
                  <displayName>3 Channels</displayName>
                  <description>Each sub-group conversion has 3 channels.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FOUR</name>
                  <displayName>4 Channels</displayName>
                  <description>Each sub-group conversion has 4 channels.</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FIVE</name>
                  <displayName>5 Channels</displayName>
                  <description>Each sub-group conversion has 5 channels.</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SIX</name>
                  <displayName>6 Channels</displayName>
                  <description>Each sub-group conversion has 6 channels.</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SEVEN</name>
                  <displayName>7 Channels</displayName>
                  <description>Each sub-group conversion has 7 channels.</description>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EIGHT</name>
                  <displayName>8 Channels</displayName>
                  <description>Each sub-group conversion has 8 channels.</description>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set during initialization to define how many channels are converted 
                  on each trigger in discontinuous mode.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJAWDEN</name>
              <displayName>Analog Watchdog on Injected Channels Enable</displayName>
              <description>
                When set, the analog watchdog function is applied to the injected 
                channels as well.
              </description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Injected Watchdog Disabled</displayName>
                  <description>Analog watchdog does not monitor injected channels.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Injected Watchdog Enabled</displayName>
                  <description>Analog watchdog monitors injected channels.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configure if the injected channels should also be guarded by 
                  the analog watchdog.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>REGAWDEN</name>
              <displayName>Analog Watchdog on Regular Channels Enable</displayName>
              <description>
                When set, the analog watchdog function is applied to the regular 
                channels.
              </description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Regular Watchdog Disabled</displayName>
                  <description>Analog watchdog does not monitor regular channels.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Regular Watchdog Enabled</displayName>
                  <description>Analog watchdog monitors regular channels.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configure if the regular channels should be guarded by 
                  the analog watchdog.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RESSEL</name>
              <displayName>Resolution Selection</displayName>
              <description>
                Configures the ADC resolution. 00 = 12-bit, 01 = 10-bit, 
                10 = 8-bit, 11 = 6-bit.
              </description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RES12</name>
                  <displayName>12-bit Resolution</displayName>
                  <description>ADC operates at 12-bit resolution.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RES10</name>
                  <displayName>10-bit Resolution</displayName>
                  <description>ADC operates at 10-bit resolution.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RES8</name>
                  <displayName>8-bit Resolution</displayName>
                  <description>ADC operates at 8-bit resolution.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RES6</name>
                  <displayName>6-bit Resolution</displayName>
                  <description>ADC operates at 6-bit resolution.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set during initialization to choose the ADC's resolution 
                  for conversions.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>OVRIEN</name>
              <displayName>Overrun Interrupt Enable</displayName>
              <description>
                Enables or disables the interrupt when an overrun occurs. An overrun
                occurs if new data overwrites old data in the data register before it 
                is read.
              </description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Interrupt Disabled</displayName>
                  <description>Overrun interrupt is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>Interrupt Enabled</displayName>
                  <description>Overrun interrupt is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically enabled if the application needs to handle data overrun 
                  events with an interrupt.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL2</name>
          <displayName>ADC Control Register 2</displayName>
          <description>
            ADC control register 2. Configures ADC enable, single/continuous operation,
            DMA behavior, data alignment, external triggers for regular and injected
            conversions, and software start triggers.
          </description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>ADCEN</name>
              <displayName>ADC Enable</displayName>
              <description>
                Enables or disables the ADC. 0 = ADC in power-down mode, 
                1 = ADC enabled.
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>ADC Disabled</displayName>
                  <description>The ADC is powered down and no conversions occur.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ADC Enabled</displayName>
                  <description>The ADC is enabled and ready for conversions.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically changed at runtime to turn the ADC on or off. 
                  However, often set once during initialization.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CONTCEN</name>
              <displayName>Continuous Conversion Enable</displayName>
              <description>
                Selects single or continuous conversion mode. 0 = single conversion, 
                1 = continuous conversion.
              </description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SINGLE</name>
                  <displayName>Single Conversion</displayName>
                  <description>The ADC performs only one conversion per trigger.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CONTINUOUS</name>
                  <displayName>Continuous Conversion</displayName>
                  <description>The ADC performs back-to-back conversions after a start.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically set during initialization depending on whether the 
                  application requires continuous sampling or single-shot conversions.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DMAEN</name>
              <displayName>DMA Mode Enable</displayName>
              <description>
                Enables or disables DMA requests when regular conversions complete 
                (in single ADC mode).
              </description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DMA Disabled</displayName>
                  <description>No DMA requests are generated after conversion completes.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>DMA Enabled</displayName>
                  <description>DMA requests are generated to transfer conversion results.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Enabled if the application wants automatic data transfers from 
                  ADC to memory without CPU intervention.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DMADISSEL</name>
              <displayName>DMA Disable Selection</displayName>
              <description>
                Specifies how DMA requests are generated when DMA is enabled 
                (in single ADC mode).
              </description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ONESHOT</name>
                  <displayName>One-Shot DMA</displayName>
                  <description>No further DMA requests after the last completed transmission.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CONT</name>
                  <displayName>Continuous DMA</displayName>
                  <description>DMA requests continue whenever data conversion occurs.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Depending on the application's data handling approach, configure 
                  if DMA stops after a single series of transfers or continues indefinitely.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>EOCSEL</name>
              <displayName>End-of-Conversion Selection</displayName>
              <description>
                Selects when the EOC flag is set.
              </description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SEQ</name>
                  <displayName>EOC After Sequence</displayName>
                  <description>EOC flag is set once per entire conversion sequence.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EACH</name>
                  <displayName>EOC After Each Conversion</displayName>
                  <description>EOC flag is set after each channel conversion within the sequence.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Chosen based on how frequently the application wants to be notified 
                  of conversion completions.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DALIGNCFG</name>
              <displayName>Data Alignment Configuration</displayName>
              <description>
                Selects the alignment of ADC conversion data.
              </description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>RIGHT</name>
                  <displayName>Right Alignment</displayName>
                  <description>Converted data is right-aligned in the ADC data register.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LEFT</name>
                  <displayName>Left Alignment</displayName>
                  <description>Converted data is left-aligned in the ADC data register.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Typically configured once during initialization to match the 
                  data handling approach of the application.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJGEXTTRGSEL</name>
              <displayName>Injected External Trigger Selection</displayName>
              <description>
                Selects the external event to start the injected group conversion.
                Refer to Table 130 in the reference manual for possible trigger sources.
              </description>
              <bitOffset>16</bitOffset>
              <bitWidth>4</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <!-- Table 130 from chapter -->
                <enumeratedValue>
                  <name>TMR1_CC4</name>
                  <displayName>TMR1 CC4</displayName>
                  <description>Timer 1 CC4 event</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR1_TRGO</name>
                  <displayName>TMR1 TRGO</displayName>
                  <description>Timer 1 TRGO event</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR2_CC1</name>
                  <displayName>TMR2 CC1</displayName>
                  <description>Timer 2 CC1 event</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR2_TRGO</name>
                  <displayName>TMR2 TRGO</displayName>
                  <description>Timer 2 TRGO event</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR3_CC2</name>
                  <displayName>TMR3 CC2</displayName>
                  <description>Timer 3 CC2 event</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR3_CC4</name>
                  <displayName>TMR3 CC4</displayName>
                  <description>Timer 3 CC4 event</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR4_CC1</name>
                  <displayName>TMR4 CC1</displayName>
                  <description>Timer 4 CC1 event</description>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR4_CC2</name>
                  <displayName>TMR4 CC2</displayName>
                  <description>Timer 4 CC2 event</description>
                  <value>7</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR4_CC3</name>
                  <displayName>TMR4 CC3</displayName>
                  <description>Timer 4 CC3 event</description>
                  <value>8</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR4_TRGO</name>
                  <displayName>TMR4 TRGO</displayName>
                  <description>Timer 4 TRGO event</description>
                  <value>9</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR5_CC4</name>
                  <displayName>TMR5 CC4</displayName>
                  <description>Timer 5 CC4 event</description>
                  <value>10</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR5_TRGO</name>
                  <displayName>TMR5 TRGO</displayName>
                  <description>Timer 5 TRGO event</description>
                  <value>11</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR8_CC2</name>
                  <displayName>TMR8 CC2</displayName>
                  <description>Timer 8 CC2 event</description>
                  <value>12</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR8_CC3</name>
                  <displayName>TMR8 CC3</displayName>
                  <description>Timer 8 CC3 event</description>
                  <value>13</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TMR8_CC4</name>
                  <displayName>TMR8 CC4</displayName>
                  <description>Timer 8 CC4 event</description>
                  <value>14</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EINT_LINE15</name>
                  <displayName>External Interrupt Line 15</displayName>
                  <description>External pin (EXTI line 15)</description>
                  <value>15</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Used to select the desired hardware trigger source for injected 
                  channel conversions.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJEXTTRGEN</name>
              <displayName>Injected External Trigger Enable</displayName>
              <description>
                Enables or disables the detection edge for the external trigger on 
                injected channels.
              </description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <displayName>Trigger Disabled</displayName>
                  <description>No external trigger detection for injected channels.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RISING</name>
                  <displayName>Rising Edge Trigger</displayName>
                  <description>Trigger on rising edge of selected external signal.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FALLING</name>
                  <displayName>Falling Edge Trigger</displayName>
                  <description>Trigger on falling edge of selected external signal.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BOTH</name>
                  <displayName>Both Edges Trigger</displayName>
                  <description>Trigger on both rising and falling edges.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configure if and how the ADC detects the external trigger edge
                  for injected conversions.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJSWSC</name>
              <displayName>Injected Software Start Conversion</displayName>
              <description>
                Software start for injected channels. Writing 1 triggers 
                injected channel conversions if external trigger is disabled 
                or set appropriately.
              </description>
              <bitOffset>22</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_START</name>
                  <displayName>Do Not Start</displayName>
                  <description>No software trigger for injected channels.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>START</name>
                  <displayName>Start Injected Conversion</displayName>
                  <description>Start injected channels conversion via software.</description>
