                  <description>Error interrupt disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Error interrupt enabled. When DMARXEN is set and one among FEFLG, OVREFLG or NEFLG is set, an interrupt will be generated.</description>
