              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>10_BITS</name>
                  <description>10 bits for LIN break detection</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>11_BITS</name>
                  <description>11 bits for LIN break detection</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>LBDIEN</name>
              <displayName>LIN Break Detection Interrupt Enable</displayName>
              <description>Enables or disables interrupts on LIN break detection. Generates an interrupt when the LBDFLG bit is set.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>Interrupt disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Interrupt enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>LBCPOEN</name>
              <displayName>Last Bit Clock Pulse Output Enable</displayName>
              <description>Enables or disables the output of the clock pulse for the last data bit in synchronous mode. This bit does not exist on UART4 or UART5.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>CPHA</name>
              <displayName>Clock Phase</displayName>
              <description>Indicates on which clock edge data sampling is conducted in synchronous mode. This bit does not exist on UART4 or UART5.</description>
