                <enumeratedValue>
                  <name>ENABLED</name>
                  <description>Interrupt enabled</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>LBCPOEN</name>
              <displayName>Last Bit Clock Pulse Output Enable</displayName>
              <description>Enables or disables the output of the clock pulse for the last data bit in synchronous mode. This bit does not exist on UART4 or UART5.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
