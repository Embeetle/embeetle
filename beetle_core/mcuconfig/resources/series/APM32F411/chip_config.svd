                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Error interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Error interrupts are usually enabled/disabled once in an initialization routine.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXBNEIEN</name>
              <displayName>RX Buffer Not Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the RX buffer becomes non-empty.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>RX buffer not empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>RX buffer not empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Interrupt usage is generally configured at initialization depending on the desired event handling.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEIEN</name>
              <displayName>TX Buffer Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the TX buffer becomes empty.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>TX buffer empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>TX buffer empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This interrupt is typically enabled or disabled once, according to whether TX events are needed.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <displayName>DATA</displayName>
          <description>data register</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>DATA</name>
              <displayName>Transmit/Receive Data</displayName>
              <description>Writes go to the transmit buffer; reads come from the receive buffer. For an 8-bit frame, only the lower 8 bits are used. For a 16-bit frame, all 16 bits are used.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This register is used continuously during operation to send and receive data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SCFG</name>
          <displayName>Inter-IC Sound (I2S) Configuration Register</displayName>
          <description>Configures the I2S parameters. This register is used only in I2S mode (not in SPI mode). Most bits can be written only when I2SEN=0 to avoid conflicts.</description>
          <addressOffset>0x1C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CHLEN</name>
              <displayName>Channel Length</displayName>
              <description>Selects the number of bits per audio channel. Must be greater than or equal to the data length. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>16-bit channel length</displayName>
                  <description>Each audio channel is 16 bits wide.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_32</name>
                  <displayName>32-bit channel length</displayName>
                  <description>Each audio channel is 32 bits wide.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Channel length is configured before enabling I2S and remains fixed during operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DATALEN</name>
              <displayName>Data Length</displayName>
              <description>Selects the data length for audio samples (16/24/32 bits). If data length is extended to 32 bits, the extra bits are forced to 0 or must be handled in two 16-bit accesses. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>16BIT</name>
                  <displayName>16-bit data length</displayName>
                  <description>Audio sample size is 16 bits.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>24BIT</name>
                  <displayName>24-bit data length</displayName>
                  <description>Audio sample size is 24 bits (two 16-bit accesses).</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>32BIT</name>
                  <displayName>32-bit data length</displayName>
                  <description>Audio sample size is 32 bits (two 16-bit accesses if using the 16-bit SPI_DATA register).</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Data length disabled</displayName>
                  <description>Not used; data length is disabled.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length is chosen at initialization and typically remains unchanged during I2S operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Selects the idle state (polarity) of the I2S clock line (CK). This bit can only be configured when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>Idle clock low</displayName>
                  <description>The clock line (CK) is low in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>Idle clock high</displayName>
                  <description>The clock line (CK) is high in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Idle clock polarity is selected prior to enabling I2S; not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SSSEL</name>
              <displayName>I2S Standard Selection</displayName>
              <description>Selects the audio standard: I2S Philips, MSB alignment, LSB alignment, or PCM. This bit can only be configured when I2SEN=0, and is not used in SPI mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>PHILIPS</name>
                  <displayName>I2S Philips standard</displayName>
                  <description>Uses the Philips I2S standard (WS toggles one bit before data).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MSB_ALIGN</name>
                  <displayName>MSB-alignment (left-justified)</displayName>
                  <description>Uses the MSB alignment standard.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_ALIGN</name>
                  <displayName>LSB-alignment (right-justified)</displayName>
                  <description>Uses the LSB alignment standard.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PCM</name>
                  <displayName>PCM standard</displayName>
                  <description>Uses the PCM short/long frame standard.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Audio protocol is configured before operation and remains unchanged once streaming begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>PFSSEL</name>
              <displayName>PCM Frame Sync Mode</displayName>
              <description>Selects short- or long-frame synchronization when PCM standard (I2SSSEL=11) is used. Not used for other standards. Can only be set when I2SEN=0.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SHORT</name>
                  <displayName>Short frame sync</displayName>
                  <description>Synchronization pulse is 1 bit wide (short frame).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LONG</name>
                  <displayName>Long frame sync</displayName>
                  <description>Synchronization pulse is 13 bits wide (long frame).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Frame sync size is a fundamental setup selected before I2S is enabled (only for PCM).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SMOD</name>
              <displayName>Master/Slave Transmit/Receive Mode</displayName>
              <description>Selects I2S master or slave, and TX or RX (So one of these four options: Slave Transmit, Slave Receive, Master Transmit or Master Receive). Can only be changed when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE_TX</name>
                  <displayName>Slave transmit</displayName>
                  <description>I2S operates as slave, transmitting data.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SLAVE_RX</name>
                  <displayName>Slave receive</displayName>
                  <description>I2S operates as slave, receiving data.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_TX</name>
                  <displayName>Master transmit</displayName>
                  <description>I2S operates as master, transmitting data.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_RX</name>
                  <displayName>Master receive</displayName>
                  <description>I2S operates as master, receiving data.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The master/slave role and TX/RX direction are configured before enabling the interface.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SEN</name>
              <displayName>I2S Enable</displayName>
              <description>Enables or disables the I2S module for audio communication. This bit can be toggled at runtime to start or stop I2S. All other configuration bits must be stable before enabling I2S.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>I2S disabled</displayName>
                  <description>The I2S module is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>I2S enabled</displayName>
                  <description>The I2S module is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Similar to SPIEN; can be set or cleared to enable/disable I2S at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MODESEL</name>
              <displayName>SPI/I2S Mode Select</displayName>
              <description>Selects whether the peripheral works in SPI mode or I2S mode. Must be set before enabling the peripheral; not allowed to change on the fly.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SPI</name>
                  <displayName>SPI mode</displayName>
                  <description>The peripheral operates in SPI mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>I2S</name>
                  <displayName>I2S mode</displayName>
                  <description>The peripheral operates in I2S mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This must be set before enabling the peripheral and cannot be changed once active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SPSC</name>
          <displayName>I2S (Inter-IC Sound) Prescaler Register</displayName>
          <description>The I2S prescaler register is used to configure the I2S clock prescaler to generate the correct audio sampling frequency. It is only valid in I2S mode (not used in SPI mode). The register must not be modified when the I2S is enabled (I2SEN=1). In particular, I2SPSC must not be set to 0 or 1.</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <!--
            According to the reference manual, the reset value is 0x0002 (0x2).
            This differs from the original SVD file, where the reset value was 0xA.
          -->
          <resetValue>0x0002</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>I2SPSC</name>
              <displayName>I2S Linear Prescaler</displayName>
              <description>Specifies the integer part of the I2S prescaler. Must not be 0 or 1. Can only be changed when I2SEN=0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This prescaler value is set before the I2S is enabled to define the desired audio sampling frequency.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ODDPSC</name>
              <displayName>Odd Prescaler Factor</displayName>
              <description>Determines whether the prescaler factor is multiplied by 2 or by (2 + 1). Can only be changed when I2SEN=0.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EVEN</name>
                  <displayName>EVEN</displayName>
                  <description>Prescaler factor = I2SPSC * 2.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ODD</name>
                  <displayName>ODD</displayName>
                  <description>Prescaler factor = (I2SPSC * 2) + 1.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Also a prescaler configuration bit that must be set before enabling I2S to achieve the correct audio clock.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MCOEN</name>
              <displayName>Master Clock Output Enable</displayName>
              <description>Enables or disables the extra master clock output pin in I2S master mode.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Master clock output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Master clock output is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is configured prior to operation if an external MCLK is needed. Not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>RXCRC</name>
          <displayName>SPI Receive CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data received in SPI mode. The width of this CRC matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXCRC</name>
              <displayName>Receive Data CRC Value</displayName>
              <description>Holds the CRC result of the received data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is updated at runtime by hardware (SPI CRC engine), and read at runtime to verify the integrity of received data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>STS</name>
          <displayName>SPI/I2S Status Register</displayName>
          <description>This register contains various status flags for SPI or I2S operation, such as buffer flags (transmit, receive), error flags (overrun, underrun, CRC error, mode fault, TI/I2S frame error), busy flag, and left/right channel indication.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0x2</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXBNEFLG</name>
              <displayName>Receive Buffer Not Empty Flag</displayName>
              <description>Indicates that the receive buffer contains valid data. In SPI mode, it is cleared by reading the SPI_DATA register. In I2S mode, it is cleared by reading the same data register.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The receive buffer is empty (no new data)</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The receive buffer contains valid data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to check if new data has been received.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEFLG</name>
              <displayName>Transmit Buffer Empty Flag</displayName>
              <description>Indicates that the transmit buffer is empty and can accept new data. In SPI/I2S mode, it is set by hardware after the data moves to the shift register.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The transmit buffer currently holds data</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The transmit buffer is empty and ready for new data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to know when it can write new data into the transmit buffer.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SCHDIR</name>
              <displayName>Sound Channel Direction</displayName>
              <description>Indicates whether the current data sample being transmitted or received belongs to the left or right audio channel (for I2S Philips/MSB/LSB modes). Not used in PCM standard.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEFT</name>
                  <displayName>Left Channel</displayName>
                  <description>Data is for the left audio channel</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RIGHT</name>
                  <displayName>Right Channel</displayName>
                  <description>Data is for the right audio channel</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware (based on WS signal) and read at runtime to identify which channel is active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>UDRFLG</name>
              <displayName>Underrun Flag</displayName>
              <description>Indicates an underrun error has occurred (mainly in I2S slave transmit mode) if the application fails to provide data in time.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_UNDERRUN</name>
                  <displayName>No Underrun</displayName>
                  <description>No underrun error occurred</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDERRUN</name>
                  <displayName>Underrun</displayName>
                  <description>Data was not written in time, causing an underrun</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware when the transmit buffer underruns. Software checks it at runtime to detect errors.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEFLG</name>
              <displayName>CRC Error Flag</displayName>
              <description>Indicates that the received CRC does not match the computed CRC in SPI mode. 0 = match (no CRC error), 1 = CRC error occurred. Cleared by writing 0 to this bit. Not used in I2S mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOERROR</name>
                  <displayName>No CRC Error</displayName>
                  <description>The received CRC matches the transmitted CRC</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>CRC Error</displayName>
                  <description>The CRC check failed</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is used at runtime to check if a SPI CRC mismatch has occurred. Cleared by writing 0.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MEFLG</name>
              <displayName>Master Mode Fault Flag</displayName>
              <description>Indicates a mode fault error in SPI master mode (e.g., NSS pulled low while configured as master). SPI is forced to slave mode if set. Cleared by read/write sequence.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_FAULT</name>
                  <displayName>No Fault</displayName>
                  <description>No master mode fault detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FAULT</name>
                  <displayName>Fault</displayName>
                  <description>Master mode fault occurred</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware if a mode fault condition arises in SPI master mode. Software checks it at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>OVRFLG</name>
              <displayName>Overrun Flag</displayName>
              <description>Indicates an overrun error occurred, typically when the received data is not read in time (SPI/I2S). Cleared by a read of SPI_DATA followed by a read of STS.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRUN</name>
                  <displayName>No Overrun</displayName>
                  <description>No unread data was overwritten</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OVERRUN</name>
                  <displayName>Overrun</displayName>
                  <description>Previously received data was lost due to not being read in time</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set at runtime by hardware when received data is overwritten. Software must check and clear it to handle the error.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BSYFLG</name>
              <displayName>Busy Flag</displayName>
              <description>Indicates that SPI/I2S is actively transmitting or receiving data.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <displayName>Idle</displayName>
                  <description>No current communication</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <displayName>Busy</displayName>
                  <description>SPI/I2S is transmitting or receiving data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware at runtime to indicate if communication is ongoing.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FFERR</name>
              <displayName>TI Frame Format Error Flag</displayName>
              <description>Indicates a frame format error in TI slave mode or a synchronization error in I2S slave mode. Cleared by reading STS.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_ERROR</name>
                  <displayName>No Error</displayName>
                  <description>No frame format error detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>Error</displayName>
                  <description>Frame format or synchronization error has been detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Hardware updates this flag at runtime if a TI or I2S frame error occurs. Software reads/clears it to detect synchronization loss.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>TXCRC</name>
          <displayName>SPI Transmit CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data transmitted in SPI mode. Its width matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>TXCRC</name>
              <displayName>Transmit Data CRC Value</displayName>
              <description>Holds the CRC result of the transmitted data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is continuously updated by hardware and read at runtime to verify the integrity of transmitted data (SPI CRC).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SPI2</name>
      <description>Serial peripheral interface</description>
      <groupName>SPI</groupName>
      <baseAddress>0x40003800</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
        <protection>n</protection>
      </addressBlock>
      <interrupt>
        <name>SPI2</name>
        <description>SPI2 global interrupt</description>
        <value>36</value>
      </interrupt>
      <registers>
        <register>
          <name>CRCPOLY</name>
          <displayName>SPI CRC Polynomial Register</displayName>
          <description>This register holds the CRC (Cyclic Redundancy Check) polynomial used for hardware-based CRC computations in SPI mode. Only the lower 16 bits are valid for defining the polynomial. This register is not used in I2S mode.</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x7</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CRCPOLY</name>
              <displayName>Cyclic Redundancy Check Polynomial Value</displayName>
              <description>This field specifies the polynomial for CRC computation (SPI mode only). When enabled via CRCEN, the hardware will use this polynomial to calculate and check the transmitted/received data. It is not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bitfield is typically configured once during SPI initialization to set the CRC polynomial.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <displayName>Serial Peripheral Interface Control Register 1</displayName>
          <description>This register is used to configure fundamental SPI parameters, including clock phase/polarity, master/slave selection, data frame format, and bidirectional mode settings. It is only used in SPI mode and not available when I2S mode is enabled.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CPHA</name>
              <displayName>Clock Phase</displayName>
              <description>Configures the clock phase used for data sampling; cannot be changed during an ongoing communication.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FIRST_EDGE</name>
                  <displayName>FIRST_EDGE</displayName>
                  <description>Data is sampled on the first clock edge (odd edge).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SECOND_EDGE</name>
                  <displayName>SECOND_EDGE</displayName>
                  <description>Data is sampled on the second clock edge (even edge).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit cannot be changed during an ongoing communication, so it's typically configured once at initialization.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Determines the idle state of the SCK line; cannot be changed during an ongoing communication.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>IDLE_LOW</displayName>
                  <description>SCK is low level in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>IDLE_HIGH</displayName>
                  <description>SCK is high level in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is also locked during communication, so it's typically set once before the SPI is enabled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MSMCFG</name>
              <displayName>Master/Slave Mode Config</displayName>
              <description>Selects master (MSMCFG=1) or slave (MSMCFG=0) mode operation; must be set before communication starts.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE</name>
                  <displayName>SLAVE</displayName>
                  <description>Device operates in slave mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER</name>
                  <displayName>MASTER</displayName>
                  <description>Device operates in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Mode selection must be done prior to communication and cannot change mid-transmission.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BRSEL</name>
              <displayName>Baud Rate Prescaler</displayName>
              <description>Sets the SPI clock prescaler, defining the baud rate as f_PCLK / (2^(BRSEL+1)) for these discrete options.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DIV2</name>
                  <displayName>DIV2</displayName>
                  <description>f_PCLK / 2</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV4</name>
                  <displayName>DIV4</displayName>
                  <description>f_PCLK / 4</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV8</name>
                  <displayName>DIV8</displayName>
                  <description>f_PCLK / 8</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV16</name>
                  <displayName>DIV16</displayName>
                  <description>f_PCLK / 16</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV32</name>
                  <displayName>DIV32</displayName>
                  <description>f_PCLK / 32</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV64</name>
                  <displayName>DIV64</displayName>
                  <description>f_PCLK / 64</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV128</name>
                  <displayName>DIV128</displayName>
                  <description>f_PCLK / 128</description>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV256</name>
                  <displayName>DIV256</displayName>
                  <description>f_PCLK / 256</description>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The baud rate prescaler cannot be changed on the fly; it's set beforehand.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SPIEN</name>
              <displayName>SPI Enable</displayName>
              <description>Enables or disables the SPI peripheral for communication.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SPI peripheral is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SPI peripheral is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is commonly toggled to start or stop SPI communication in normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>LSBSEL</name>
              <displayName>LSB First Select</displayName>
              <description>Determines whether data is transmitted with MSB-first or LSB-first ordering.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MSB_FIRST</name>
                  <displayName>MSB_FIRST</displayName>
                  <description>MSB is transmitted first.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_FIRST</name>
                  <displayName>LSB_FIRST</displayName>
                  <description>LSB is transmitted first.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically set once before communication starts; changing data order mid-communication is not advised.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ISSEL</name>
              <displayName>Internal NSS Level</displayName>
              <description>Sets the internal NSS level when software NSS mode is enabled.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NSS_LOW</name>
                  <displayName>NSS_LOW</displayName>
                  <description>Internal NSS is driven low.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NSS_HIGH</name>
                  <displayName>NSS_HIGH</displayName>
                  <description>Internal NSS is driven high.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>In software NSS mode, user code may toggle NSS at runtime to control slave selection.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSEN</name>
              <displayName>Software NSS Enable</displayName>
              <description>Enables or disables software slave management (SSM) for controlling NSS.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Software slave management disabled; external NSS is used.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Software slave management enabled; internal NSS is used.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically configured once depending on whether hardware or software NSS control is desired.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXOMEN</name>
              <displayName>Receive-Only Mode Enable</displayName>
              <description>Enables full-duplex (transmit/receive) or receive-only mode on the SPI lines.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FULL_DUPLEX</name>
                  <displayName>FULL_DUPLEX</displayName>
                  <description>Full-duplex transmit and receive.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RECEIVE_ONLY</name>
                  <displayName>RECEIVE_ONLY</displayName>
                  <description>Receive-only mode (MOSI is unused).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This determines whether SPI transmits data or not, typically set before enabling the peripheral.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DFLSEL</name>
              <displayName>Data Frame Format Select</displayName>
              <description>Selects either 8-bit or 16-bit data frame format for SPI transmissions.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_8</name>
                  <displayName>BIT_8</displayName>
                  <description>8-bit data frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>BIT_16</displayName>
                  <description>16-bit data frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length must be set before communication begins and cannot be changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCNXT</name>
              <displayName>CRC Transfer Next</displayName>
              <description>Indicates whether the next transmitted data is sourced from the TX buffer or the CRC register.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TX_BUFFER</name>
                  <displayName>TX_BUFFER</displayName>
                  <description>Next transmitted data is taken from the TX buffer.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CRC_REG</name>
                  <displayName>CRC_REGISTER</displayName>
                  <description>Next transmitted data is taken from the CRC register.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is used when appending CRC after sending all data, so it may be changed during normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEN</name>
              <displayName>CRC Calculation Enable</displayName>
              <description>Enables or disables the hardware-based CRC calculation for SPI in full-duplex mode.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>CRC calculation is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>CRC calculation is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Must be enabled or disabled prior to communication, typically only changed when SPI is not active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMOEN</name>
              <displayName>Bidirectional Mode Output Enable</displayName>
              <description>Selects output (TX-only) or input (RX-only) when in single-line bidirectional mode.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>INPUT</name>
                  <displayName>INPUT</displayName>
                  <description>Bidirectional line is used for input only.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OUTPUT</name>
                  <displayName>OUTPUT</displayName>
                  <description>Bidirectional line is used for output only.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Determines direction in single-line mode, set before the communication begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMEN</name>
              <displayName>Bidirectional Data Mode Enable</displayName>
              <description>Enables single-line bidirectional mode (BMEN=1) or two-line unidirectional mode (BMEN=0).</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TWO_LINE</name>
                  <displayName>TWO_LINE</displayName>
                  <description>Two-line unidirectional mode enabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIDIRECTIONAL</name>
                  <displayName>BIDIRECTIONAL</displayName>
                  <description>Single-line bidirectional mode enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Choosing single-line or two-line mode is a fundamental configuration done before enabling SPI.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL2</name>
          <displayName>Serial Peripheral Interface Control Register 2</displayName>
          <description>This register provides advanced control features for the SPI peripheral, such as enabling DMA requests, configuring the SS (NSS) output, selecting the SPI frame format (Motorola or TI mode) and enabling interrupts for various SPI-related events.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXDEN</name>
              <displayName>Receive DMA Enable</displayName>
              <description>Enables or disables the DMA request when the RX buffer is not empty.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for receive is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for receive is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how RX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXDEN</name>
              <displayName>Transmit DMA Enable</displayName>
              <description>Enables or disables the DMA request when the TX buffer is empty.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for transmit is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for transmit is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how TX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSOEN</name>
              <displayName>SS (NSS) Output Enable</displayName>
              <description>Enables or disables the SS (NSS) output when operating in master mode.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SS (NSS) output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SS (NSS) output is enabled in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Usually configured at initialization in master mode to determine if NSS is driven automatically.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FRFCFG</name>
              <displayName>Frame Format Configure</displayName>
              <description>Selects SPI Motorola mode (FRFCFG=0) or SPI TI mode (FRFCFG=1).</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MOTOROLA</name>
                  <displayName>MOTOROLA</displayName>
                  <description>SPI Motorola frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TI</name>
                  <displayName>TI</displayName>
                  <description>SPI TI frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Format is chosen prior to communication and isn't typically changed at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ERRIEN</name>
              <displayName>Error Interrupt Enable</displayName>
              <description>Enables or disables interrupts for SPI error flags (e.g., overrun or CRC errors).</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Error interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Error interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Error interrupts are usually enabled/disabled once in an initialization routine.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXBNEIEN</name>
              <displayName>RX Buffer Not Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the RX buffer becomes non-empty.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>RX buffer not empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>RX buffer not empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Interrupt usage is generally configured at initialization depending on the desired event handling.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEIEN</name>
              <displayName>TX Buffer Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the TX buffer becomes empty.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>TX buffer empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>TX buffer empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This interrupt is typically enabled or disabled once, according to whether TX events are needed.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <displayName>DATA</displayName>
          <description>data register</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>DATA</name>
              <displayName>Transmit/Receive Data</displayName>
              <description>Writes go to the transmit buffer; reads come from the receive buffer. For an 8-bit frame, only the lower 8 bits are used. For a 16-bit frame, all 16 bits are used.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This register is used continuously during operation to send and receive data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SCFG</name>
          <displayName>Inter-IC Sound (I2S) Configuration Register</displayName>
          <description>Configures the I2S parameters. This register is used only in I2S mode (not in SPI mode). Most bits can be written only when I2SEN=0 to avoid conflicts.</description>
          <addressOffset>0x1C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CHLEN</name>
              <displayName>Channel Length</displayName>
              <description>Selects the number of bits per audio channel. Must be greater than or equal to the data length. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>16-bit channel length</displayName>
                  <description>Each audio channel is 16 bits wide.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_32</name>
                  <displayName>32-bit channel length</displayName>
                  <description>Each audio channel is 32 bits wide.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Channel length is configured before enabling I2S and remains fixed during operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DATALEN</name>
              <displayName>Data Length</displayName>
              <description>Selects the data length for audio samples (16/24/32 bits). If data length is extended to 32 bits, the extra bits are forced to 0 or must be handled in two 16-bit accesses. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>16BIT</name>
                  <displayName>16-bit data length</displayName>
                  <description>Audio sample size is 16 bits.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>24BIT</name>
                  <displayName>24-bit data length</displayName>
                  <description>Audio sample size is 24 bits (two 16-bit accesses).</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>32BIT</name>
                  <displayName>32-bit data length</displayName>
                  <description>Audio sample size is 32 bits (two 16-bit accesses if using the 16-bit SPI_DATA register).</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Data length disabled</displayName>
                  <description>Not used; data length is disabled.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length is chosen at initialization and typically remains unchanged during I2S operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Selects the idle state (polarity) of the I2S clock line (CK). This bit can only be configured when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>Idle clock low</displayName>
                  <description>The clock line (CK) is low in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>Idle clock high</displayName>
                  <description>The clock line (CK) is high in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Idle clock polarity is selected prior to enabling I2S; not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SSSEL</name>
              <displayName>I2S Standard Selection</displayName>
              <description>Selects the audio standard: I2S Philips, MSB alignment, LSB alignment, or PCM. This bit can only be configured when I2SEN=0, and is not used in SPI mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>PHILIPS</name>
                  <displayName>I2S Philips standard</displayName>
                  <description>Uses the Philips I2S standard (WS toggles one bit before data).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MSB_ALIGN</name>
                  <displayName>MSB-alignment (left-justified)</displayName>
                  <description>Uses the MSB alignment standard.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_ALIGN</name>
                  <displayName>LSB-alignment (right-justified)</displayName>
                  <description>Uses the LSB alignment standard.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PCM</name>
                  <displayName>PCM standard</displayName>
                  <description>Uses the PCM short/long frame standard.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Audio protocol is configured before operation and remains unchanged once streaming begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>PFSSEL</name>
              <displayName>PCM Frame Sync Mode</displayName>
              <description>Selects short- or long-frame synchronization when PCM standard (I2SSSEL=11) is used. Not used for other standards. Can only be set when I2SEN=0.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SHORT</name>
                  <displayName>Short frame sync</displayName>
                  <description>Synchronization pulse is 1 bit wide (short frame).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LONG</name>
                  <displayName>Long frame sync</displayName>
                  <description>Synchronization pulse is 13 bits wide (long frame).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Frame sync size is a fundamental setup selected before I2S is enabled (only for PCM).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SMOD</name>
              <displayName>Master/Slave Transmit/Receive Mode</displayName>
              <description>Selects I2S master or slave, and TX or RX (So one of these four options: Slave Transmit, Slave Receive, Master Transmit or Master Receive). Can only be changed when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE_TX</name>
                  <displayName>Slave transmit</displayName>
                  <description>I2S operates as slave, transmitting data.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SLAVE_RX</name>
                  <displayName>Slave receive</displayName>
                  <description>I2S operates as slave, receiving data.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_TX</name>
                  <displayName>Master transmit</displayName>
                  <description>I2S operates as master, transmitting data.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_RX</name>
                  <displayName>Master receive</displayName>
                  <description>I2S operates as master, receiving data.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The master/slave role and TX/RX direction are configured before enabling the interface.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SEN</name>
              <displayName>I2S Enable</displayName>
              <description>Enables or disables the I2S module for audio communication. This bit can be toggled at runtime to start or stop I2S. All other configuration bits must be stable before enabling I2S.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>I2S disabled</displayName>
                  <description>The I2S module is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>I2S enabled</displayName>
                  <description>The I2S module is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Similar to SPIEN; can be set or cleared to enable/disable I2S at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MODESEL</name>
              <displayName>SPI/I2S Mode Select</displayName>
              <description>Selects whether the peripheral works in SPI mode or I2S mode. Must be set before enabling the peripheral; not allowed to change on the fly.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SPI</name>
                  <displayName>SPI mode</displayName>
                  <description>The peripheral operates in SPI mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>I2S</name>
                  <displayName>I2S mode</displayName>
                  <description>The peripheral operates in I2S mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This must be set before enabling the peripheral and cannot be changed once active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SPSC</name>
          <displayName>I2S (Inter-IC Sound) Prescaler Register</displayName>
          <description>The I2S prescaler register is used to configure the I2S clock prescaler to generate the correct audio sampling frequency. It is only valid in I2S mode (not used in SPI mode). The register must not be modified when the I2S is enabled (I2SEN=1). In particular, I2SPSC must not be set to 0 or 1.</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <!--
            According to the reference manual, the reset value is 0x0002 (0x2).
            This differs from the original SVD file, where the reset value was 0xA.
          -->
          <resetValue>0x0002</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>I2SPSC</name>
              <displayName>I2S Linear Prescaler</displayName>
              <description>Specifies the integer part of the I2S prescaler. Must not be 0 or 1. Can only be changed when I2SEN=0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This prescaler value is set before the I2S is enabled to define the desired audio sampling frequency.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ODDPSC</name>
              <displayName>Odd Prescaler Factor</displayName>
              <description>Determines whether the prescaler factor is multiplied by 2 or by (2 + 1). Can only be changed when I2SEN=0.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EVEN</name>
                  <displayName>EVEN</displayName>
                  <description>Prescaler factor = I2SPSC * 2.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ODD</name>
                  <displayName>ODD</displayName>
                  <description>Prescaler factor = (I2SPSC * 2) + 1.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Also a prescaler configuration bit that must be set before enabling I2S to achieve the correct audio clock.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MCOEN</name>
              <displayName>Master Clock Output Enable</displayName>
              <description>Enables or disables the extra master clock output pin in I2S master mode.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Master clock output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Master clock output is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is configured prior to operation if an external MCLK is needed. Not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>RXCRC</name>
          <displayName>SPI Receive CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data received in SPI mode. The width of this CRC matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXCRC</name>
              <displayName>Receive Data CRC Value</displayName>
              <description>Holds the CRC result of the received data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is updated at runtime by hardware (SPI CRC engine), and read at runtime to verify the integrity of received data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>STS</name>
          <displayName>SPI/I2S Status Register</displayName>
          <description>This register contains various status flags for SPI or I2S operation, such as buffer flags (transmit, receive), error flags (overrun, underrun, CRC error, mode fault, TI/I2S frame error), busy flag, and left/right channel indication.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0x2</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXBNEFLG</name>
              <displayName>Receive Buffer Not Empty Flag</displayName>
              <description>Indicates that the receive buffer contains valid data. In SPI mode, it is cleared by reading the SPI_DATA register. In I2S mode, it is cleared by reading the same data register.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The receive buffer is empty (no new data)</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The receive buffer contains valid data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to check if new data has been received.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEFLG</name>
              <displayName>Transmit Buffer Empty Flag</displayName>
              <description>Indicates that the transmit buffer is empty and can accept new data. In SPI/I2S mode, it is set by hardware after the data moves to the shift register.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The transmit buffer currently holds data</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The transmit buffer is empty and ready for new data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to know when it can write new data into the transmit buffer.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SCHDIR</name>
              <displayName>Sound Channel Direction</displayName>
              <description>Indicates whether the current data sample being transmitted or received belongs to the left or right audio channel (for I2S Philips/MSB/LSB modes). Not used in PCM standard.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEFT</name>
                  <displayName>Left Channel</displayName>
                  <description>Data is for the left audio channel</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RIGHT</name>
                  <displayName>Right Channel</displayName>
                  <description>Data is for the right audio channel</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware (based on WS signal) and read at runtime to identify which channel is active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>UDRFLG</name>
              <displayName>Underrun Flag</displayName>
              <description>Indicates an underrun error has occurred (mainly in I2S slave transmit mode) if the application fails to provide data in time.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_UNDERRUN</name>
                  <displayName>No Underrun</displayName>
                  <description>No underrun error occurred</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDERRUN</name>
                  <displayName>Underrun</displayName>
                  <description>Data was not written in time, causing an underrun</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware when the transmit buffer underruns. Software checks it at runtime to detect errors.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEFLG</name>
              <displayName>CRC Error Flag</displayName>
              <description>Indicates that the received CRC does not match the computed CRC in SPI mode. 0 = match (no CRC error), 1 = CRC error occurred. Cleared by writing 0 to this bit. Not used in I2S mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOERROR</name>
                  <displayName>No CRC Error</displayName>
                  <description>The received CRC matches the transmitted CRC</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>CRC Error</displayName>
                  <description>The CRC check failed</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is used at runtime to check if a SPI CRC mismatch has occurred. Cleared by writing 0.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MEFLG</name>
              <displayName>Master Mode Fault Flag</displayName>
              <description>Indicates a mode fault error in SPI master mode (e.g., NSS pulled low while configured as master). SPI is forced to slave mode if set. Cleared by read/write sequence.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_FAULT</name>
                  <displayName>No Fault</displayName>
                  <description>No master mode fault detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FAULT</name>
                  <displayName>Fault</displayName>
                  <description>Master mode fault occurred</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware if a mode fault condition arises in SPI master mode. Software checks it at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>OVRFLG</name>
              <displayName>Overrun Flag</displayName>
              <description>Indicates an overrun error occurred, typically when the received data is not read in time (SPI/I2S). Cleared by a read of SPI_DATA followed by a read of STS.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRUN</name>
                  <displayName>No Overrun</displayName>
                  <description>No unread data was overwritten</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OVERRUN</name>
                  <displayName>Overrun</displayName>
                  <description>Previously received data was lost due to not being read in time</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set at runtime by hardware when received data is overwritten. Software must check and clear it to handle the error.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BSYFLG</name>
              <displayName>Busy Flag</displayName>
              <description>Indicates that SPI/I2S is actively transmitting or receiving data.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <displayName>Idle</displayName>
                  <description>No current communication</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <displayName>Busy</displayName>
                  <description>SPI/I2S is transmitting or receiving data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware at runtime to indicate if communication is ongoing.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FFERR</name>
              <displayName>TI Frame Format Error Flag</displayName>
              <description>Indicates a frame format error in TI slave mode or a synchronization error in I2S slave mode. Cleared by reading STS.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_ERROR</name>
                  <displayName>No Error</displayName>
                  <description>No frame format error detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>Error</displayName>
                  <description>Frame format or synchronization error has been detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Hardware updates this flag at runtime if a TI or I2S frame error occurs. Software reads/clears it to detect synchronization loss.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>TXCRC</name>
          <displayName>SPI Transmit CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data transmitted in SPI mode. Its width matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>TXCRC</name>
              <displayName>Transmit Data CRC Value</displayName>
              <description>Holds the CRC result of the transmitted data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is continuously updated by hardware and read at runtime to verify the integrity of transmitted data (SPI CRC).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SPI3</name>
      <description>Serial peripheral interface</description>
      <groupName>SPI</groupName>
      <baseAddress>0x40003C00</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
        <protection>n</protection>
      </addressBlock>
      <interrupt>
        <name>SPI3</name>
        <description>SPI3 global interrupt</description>
        <value>51</value>
      </interrupt>
      <registers>
        <register>
          <name>CRCPOLY</name>
          <displayName>SPI CRC Polynomial Register</displayName>
          <description>This register holds the CRC (Cyclic Redundancy Check) polynomial used for hardware-based CRC computations in SPI mode. Only the lower 16 bits are valid for defining the polynomial. This register is not used in I2S mode.</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x7</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CRCPOLY</name>
              <displayName>Cyclic Redundancy Check Polynomial Value</displayName>
              <description>This field specifies the polynomial for CRC computation (SPI mode only). When enabled via CRCEN, the hardware will use this polynomial to calculate and check the transmitted/received data. It is not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bitfield is typically configured once during SPI initialization to set the CRC polynomial.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <displayName>Serial Peripheral Interface Control Register 1</displayName>
          <description>This register is used to configure fundamental SPI parameters, including clock phase/polarity, master/slave selection, data frame format, and bidirectional mode settings. It is only used in SPI mode and not available when I2S mode is enabled.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CPHA</name>
              <displayName>Clock Phase</displayName>
              <description>Configures the clock phase used for data sampling; cannot be changed during an ongoing communication.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FIRST_EDGE</name>
                  <displayName>FIRST_EDGE</displayName>
                  <description>Data is sampled on the first clock edge (odd edge).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SECOND_EDGE</name>
                  <displayName>SECOND_EDGE</displayName>
                  <description>Data is sampled on the second clock edge (even edge).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit cannot be changed during an ongoing communication, so it's typically configured once at initialization.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Determines the idle state of the SCK line; cannot be changed during an ongoing communication.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>IDLE_LOW</displayName>
                  <description>SCK is low level in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>IDLE_HIGH</displayName>
                  <description>SCK is high level in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is also locked during communication, so it's typically set once before the SPI is enabled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MSMCFG</name>
              <displayName>Master/Slave Mode Config</displayName>
              <description>Selects master (MSMCFG=1) or slave (MSMCFG=0) mode operation; must be set before communication starts.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE</name>
                  <displayName>SLAVE</displayName>
                  <description>Device operates in slave mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER</name>
                  <displayName>MASTER</displayName>
                  <description>Device operates in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Mode selection must be done prior to communication and cannot change mid-transmission.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BRSEL</name>
              <displayName>Baud Rate Prescaler</displayName>
              <description>Sets the SPI clock prescaler, defining the baud rate as f_PCLK / (2^(BRSEL+1)) for these discrete options.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DIV2</name>
                  <displayName>DIV2</displayName>
                  <description>f_PCLK / 2</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV4</name>
                  <displayName>DIV4</displayName>
                  <description>f_PCLK / 4</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV8</name>
                  <displayName>DIV8</displayName>
                  <description>f_PCLK / 8</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV16</name>
                  <displayName>DIV16</displayName>
                  <description>f_PCLK / 16</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV32</name>
                  <displayName>DIV32</displayName>
                  <description>f_PCLK / 32</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV64</name>
                  <displayName>DIV64</displayName>
                  <description>f_PCLK / 64</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV128</name>
                  <displayName>DIV128</displayName>
                  <description>f_PCLK / 128</description>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV256</name>
                  <displayName>DIV256</displayName>
                  <description>f_PCLK / 256</description>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The baud rate prescaler cannot be changed on the fly; it's set beforehand.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SPIEN</name>
              <displayName>SPI Enable</displayName>
              <description>Enables or disables the SPI peripheral for communication.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SPI peripheral is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SPI peripheral is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is commonly toggled to start or stop SPI communication in normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>LSBSEL</name>
              <displayName>LSB First Select</displayName>
              <description>Determines whether data is transmitted with MSB-first or LSB-first ordering.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MSB_FIRST</name>
                  <displayName>MSB_FIRST</displayName>
                  <description>MSB is transmitted first.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_FIRST</name>
                  <displayName>LSB_FIRST</displayName>
                  <description>LSB is transmitted first.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically set once before communication starts; changing data order mid-communication is not advised.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ISSEL</name>
              <displayName>Internal NSS Level</displayName>
              <description>Sets the internal NSS level when software NSS mode is enabled.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NSS_LOW</name>
                  <displayName>NSS_LOW</displayName>
                  <description>Internal NSS is driven low.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NSS_HIGH</name>
                  <displayName>NSS_HIGH</displayName>
                  <description>Internal NSS is driven high.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>In software NSS mode, user code may toggle NSS at runtime to control slave selection.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSEN</name>
              <displayName>Software NSS Enable</displayName>
              <description>Enables or disables software slave management (SSM) for controlling NSS.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Software slave management disabled; external NSS is used.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Software slave management enabled; internal NSS is used.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically configured once depending on whether hardware or software NSS control is desired.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXOMEN</name>
              <displayName>Receive-Only Mode Enable</displayName>
              <description>Enables full-duplex (transmit/receive) or receive-only mode on the SPI lines.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FULL_DUPLEX</name>
                  <displayName>FULL_DUPLEX</displayName>
                  <description>Full-duplex transmit and receive.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RECEIVE_ONLY</name>
                  <displayName>RECEIVE_ONLY</displayName>
                  <description>Receive-only mode (MOSI is unused).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This determines whether SPI transmits data or not, typically set before enabling the peripheral.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DFLSEL</name>
              <displayName>Data Frame Format Select</displayName>
              <description>Selects either 8-bit or 16-bit data frame format for SPI transmissions.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_8</name>
                  <displayName>BIT_8</displayName>
                  <description>8-bit data frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>BIT_16</displayName>
                  <description>16-bit data frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length must be set before communication begins and cannot be changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCNXT</name>
              <displayName>CRC Transfer Next</displayName>
              <description>Indicates whether the next transmitted data is sourced from the TX buffer or the CRC register.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TX_BUFFER</name>
                  <displayName>TX_BUFFER</displayName>
                  <description>Next transmitted data is taken from the TX buffer.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CRC_REG</name>
                  <displayName>CRC_REGISTER</displayName>
                  <description>Next transmitted data is taken from the CRC register.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is used when appending CRC after sending all data, so it may be changed during normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEN</name>
              <displayName>CRC Calculation Enable</displayName>
              <description>Enables or disables the hardware-based CRC calculation for SPI in full-duplex mode.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>CRC calculation is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>CRC calculation is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Must be enabled or disabled prior to communication, typically only changed when SPI is not active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMOEN</name>
              <displayName>Bidirectional Mode Output Enable</displayName>
              <description>Selects output (TX-only) or input (RX-only) when in single-line bidirectional mode.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>INPUT</name>
                  <displayName>INPUT</displayName>
                  <description>Bidirectional line is used for input only.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OUTPUT</name>
                  <displayName>OUTPUT</displayName>
                  <description>Bidirectional line is used for output only.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Determines direction in single-line mode, set before the communication begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMEN</name>
              <displayName>Bidirectional Data Mode Enable</displayName>
              <description>Enables single-line bidirectional mode (BMEN=1) or two-line unidirectional mode (BMEN=0).</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TWO_LINE</name>
                  <displayName>TWO_LINE</displayName>
                  <description>Two-line unidirectional mode enabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIDIRECTIONAL</name>
                  <displayName>BIDIRECTIONAL</displayName>
                  <description>Single-line bidirectional mode enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Choosing single-line or two-line mode is a fundamental configuration done before enabling SPI.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL2</name>
          <displayName>Serial Peripheral Interface Control Register 2</displayName>
          <description>This register provides advanced control features for the SPI peripheral, such as enabling DMA requests, configuring the SS (NSS) output, selecting the SPI frame format (Motorola or TI mode) and enabling interrupts for various SPI-related events.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXDEN</name>
              <displayName>Receive DMA Enable</displayName>
              <description>Enables or disables the DMA request when the RX buffer is not empty.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for receive is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for receive is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how RX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXDEN</name>
              <displayName>Transmit DMA Enable</displayName>
              <description>Enables or disables the DMA request when the TX buffer is empty.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for transmit is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for transmit is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how TX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSOEN</name>
              <displayName>SS (NSS) Output Enable</displayName>
              <description>Enables or disables the SS (NSS) output when operating in master mode.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SS (NSS) output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SS (NSS) output is enabled in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Usually configured at initialization in master mode to determine if NSS is driven automatically.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FRFCFG</name>
              <displayName>Frame Format Configure</displayName>
              <description>Selects SPI Motorola mode (FRFCFG=0) or SPI TI mode (FRFCFG=1).</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MOTOROLA</name>
                  <displayName>MOTOROLA</displayName>
                  <description>SPI Motorola frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TI</name>
                  <displayName>TI</displayName>
                  <description>SPI TI frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Format is chosen prior to communication and isn't typically changed at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ERRIEN</name>
              <displayName>Error Interrupt Enable</displayName>
              <description>Enables or disables interrupts for SPI error flags (e.g., overrun or CRC errors).</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Error interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Error interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Error interrupts are usually enabled/disabled once in an initialization routine.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXBNEIEN</name>
              <displayName>RX Buffer Not Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the RX buffer becomes non-empty.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>RX buffer not empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>RX buffer not empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Interrupt usage is generally configured at initialization depending on the desired event handling.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEIEN</name>
              <displayName>TX Buffer Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the TX buffer becomes empty.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>TX buffer empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>TX buffer empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This interrupt is typically enabled or disabled once, according to whether TX events are needed.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <displayName>DATA</displayName>
          <description>data register</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>DATA</name>
              <displayName>Transmit/Receive Data</displayName>
              <description>Writes go to the transmit buffer; reads come from the receive buffer. For an 8-bit frame, only the lower 8 bits are used. For a 16-bit frame, all 16 bits are used.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This register is used continuously during operation to send and receive data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SCFG</name>
          <displayName>Inter-IC Sound (I2S) Configuration Register</displayName>
          <description>Configures the I2S parameters. This register is used only in I2S mode (not in SPI mode). Most bits can be written only when I2SEN=0 to avoid conflicts.</description>
          <addressOffset>0x1C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CHLEN</name>
              <displayName>Channel Length</displayName>
              <description>Selects the number of bits per audio channel. Must be greater than or equal to the data length. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>16-bit channel length</displayName>
                  <description>Each audio channel is 16 bits wide.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_32</name>
                  <displayName>32-bit channel length</displayName>
                  <description>Each audio channel is 32 bits wide.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Channel length is configured before enabling I2S and remains fixed during operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DATALEN</name>
              <displayName>Data Length</displayName>
              <description>Selects the data length for audio samples (16/24/32 bits). If data length is extended to 32 bits, the extra bits are forced to 0 or must be handled in two 16-bit accesses. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>16BIT</name>
                  <displayName>16-bit data length</displayName>
                  <description>Audio sample size is 16 bits.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>24BIT</name>
                  <displayName>24-bit data length</displayName>
                  <description>Audio sample size is 24 bits (two 16-bit accesses).</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>32BIT</name>
                  <displayName>32-bit data length</displayName>
                  <description>Audio sample size is 32 bits (two 16-bit accesses if using the 16-bit SPI_DATA register).</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Data length disabled</displayName>
                  <description>Not used; data length is disabled.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length is chosen at initialization and typically remains unchanged during I2S operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Selects the idle state (polarity) of the I2S clock line (CK). This bit can only be configured when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>Idle clock low</displayName>
                  <description>The clock line (CK) is low in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>Idle clock high</displayName>
                  <description>The clock line (CK) is high in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Idle clock polarity is selected prior to enabling I2S; not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SSSEL</name>
              <displayName>I2S Standard Selection</displayName>
              <description>Selects the audio standard: I2S Philips, MSB alignment, LSB alignment, or PCM. This bit can only be configured when I2SEN=0, and is not used in SPI mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>PHILIPS</name>
                  <displayName>I2S Philips standard</displayName>
                  <description>Uses the Philips I2S standard (WS toggles one bit before data).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MSB_ALIGN</name>
                  <displayName>MSB-alignment (left-justified)</displayName>
                  <description>Uses the MSB alignment standard.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_ALIGN</name>
                  <displayName>LSB-alignment (right-justified)</displayName>
                  <description>Uses the LSB alignment standard.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PCM</name>
                  <displayName>PCM standard</displayName>
                  <description>Uses the PCM short/long frame standard.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Audio protocol is configured before operation and remains unchanged once streaming begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>PFSSEL</name>
              <displayName>PCM Frame Sync Mode</displayName>
              <description>Selects short- or long-frame synchronization when PCM standard (I2SSSEL=11) is used. Not used for other standards. Can only be set when I2SEN=0.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SHORT</name>
                  <displayName>Short frame sync</displayName>
                  <description>Synchronization pulse is 1 bit wide (short frame).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LONG</name>
                  <displayName>Long frame sync</displayName>
                  <description>Synchronization pulse is 13 bits wide (long frame).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Frame sync size is a fundamental setup selected before I2S is enabled (only for PCM).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SMOD</name>
              <displayName>Master/Slave Transmit/Receive Mode</displayName>
              <description>Selects I2S master or slave, and TX or RX (So one of these four options: Slave Transmit, Slave Receive, Master Transmit or Master Receive). Can only be changed when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE_TX</name>
                  <displayName>Slave transmit</displayName>
                  <description>I2S operates as slave, transmitting data.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SLAVE_RX</name>
                  <displayName>Slave receive</displayName>
                  <description>I2S operates as slave, receiving data.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_TX</name>
                  <displayName>Master transmit</displayName>
                  <description>I2S operates as master, transmitting data.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_RX</name>
                  <displayName>Master receive</displayName>
                  <description>I2S operates as master, receiving data.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The master/slave role and TX/RX direction are configured before enabling the interface.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SEN</name>
              <displayName>I2S Enable</displayName>
              <description>Enables or disables the I2S module for audio communication. This bit can be toggled at runtime to start or stop I2S. All other configuration bits must be stable before enabling I2S.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>I2S disabled</displayName>
                  <description>The I2S module is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>I2S enabled</displayName>
                  <description>The I2S module is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Similar to SPIEN; can be set or cleared to enable/disable I2S at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MODESEL</name>
              <displayName>SPI/I2S Mode Select</displayName>
              <description>Selects whether the peripheral works in SPI mode or I2S mode. Must be set before enabling the peripheral; not allowed to change on the fly.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SPI</name>
                  <displayName>SPI mode</displayName>
                  <description>The peripheral operates in SPI mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>I2S</name>
                  <displayName>I2S mode</displayName>
                  <description>The peripheral operates in I2S mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This must be set before enabling the peripheral and cannot be changed once active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SPSC</name>
          <displayName>I2S (Inter-IC Sound) Prescaler Register</displayName>
          <description>The I2S prescaler register is used to configure the I2S clock prescaler to generate the correct audio sampling frequency. It is only valid in I2S mode (not used in SPI mode). The register must not be modified when the I2S is enabled (I2SEN=1). In particular, I2SPSC must not be set to 0 or 1.</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <!--
            According to the reference manual, the reset value is 0x0002 (0x2).
            This differs from the original SVD file, where the reset value was 0xA.
          -->
          <resetValue>0x0002</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>I2SPSC</name>
              <displayName>I2S Linear Prescaler</displayName>
              <description>Specifies the integer part of the I2S prescaler. Must not be 0 or 1. Can only be changed when I2SEN=0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This prescaler value is set before the I2S is enabled to define the desired audio sampling frequency.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ODDPSC</name>
              <displayName>Odd Prescaler Factor</displayName>
              <description>Determines whether the prescaler factor is multiplied by 2 or by (2 + 1). Can only be changed when I2SEN=0.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EVEN</name>
                  <displayName>EVEN</displayName>
                  <description>Prescaler factor = I2SPSC * 2.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ODD</name>
                  <displayName>ODD</displayName>
                  <description>Prescaler factor = (I2SPSC * 2) + 1.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Also a prescaler configuration bit that must be set before enabling I2S to achieve the correct audio clock.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MCOEN</name>
              <displayName>Master Clock Output Enable</displayName>
              <description>Enables or disables the extra master clock output pin in I2S master mode.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Master clock output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Master clock output is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is configured prior to operation if an external MCLK is needed. Not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>RXCRC</name>
          <displayName>SPI Receive CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data received in SPI mode. The width of this CRC matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXCRC</name>
              <displayName>Receive Data CRC Value</displayName>
              <description>Holds the CRC result of the received data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is updated at runtime by hardware (SPI CRC engine), and read at runtime to verify the integrity of received data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>STS</name>
          <displayName>SPI/I2S Status Register</displayName>
          <description>This register contains various status flags for SPI or I2S operation, such as buffer flags (transmit, receive), error flags (overrun, underrun, CRC error, mode fault, TI/I2S frame error), busy flag, and left/right channel indication.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0x2</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXBNEFLG</name>
              <displayName>Receive Buffer Not Empty Flag</displayName>
              <description>Indicates that the receive buffer contains valid data. In SPI mode, it is cleared by reading the SPI_DATA register. In I2S mode, it is cleared by reading the same data register.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The receive buffer is empty (no new data)</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The receive buffer contains valid data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to check if new data has been received.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEFLG</name>
              <displayName>Transmit Buffer Empty Flag</displayName>
              <description>Indicates that the transmit buffer is empty and can accept new data. In SPI/I2S mode, it is set by hardware after the data moves to the shift register.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The transmit buffer currently holds data</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The transmit buffer is empty and ready for new data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to know when it can write new data into the transmit buffer.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SCHDIR</name>
              <displayName>Sound Channel Direction</displayName>
              <description>Indicates whether the current data sample being transmitted or received belongs to the left or right audio channel (for I2S Philips/MSB/LSB modes). Not used in PCM standard.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEFT</name>
                  <displayName>Left Channel</displayName>
                  <description>Data is for the left audio channel</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RIGHT</name>
                  <displayName>Right Channel</displayName>
                  <description>Data is for the right audio channel</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware (based on WS signal) and read at runtime to identify which channel is active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>UDRFLG</name>
              <displayName>Underrun Flag</displayName>
              <description>Indicates an underrun error has occurred (mainly in I2S slave transmit mode) if the application fails to provide data in time.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_UNDERRUN</name>
                  <displayName>No Underrun</displayName>
                  <description>No underrun error occurred</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDERRUN</name>
                  <displayName>Underrun</displayName>
                  <description>Data was not written in time, causing an underrun</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware when the transmit buffer underruns. Software checks it at runtime to detect errors.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEFLG</name>
              <displayName>CRC Error Flag</displayName>
              <description>Indicates that the received CRC does not match the computed CRC in SPI mode. 0 = match (no CRC error), 1 = CRC error occurred. Cleared by writing 0 to this bit. Not used in I2S mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOERROR</name>
                  <displayName>No CRC Error</displayName>
                  <description>The received CRC matches the transmitted CRC</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>CRC Error</displayName>
                  <description>The CRC check failed</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is used at runtime to check if a SPI CRC mismatch has occurred. Cleared by writing 0.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MEFLG</name>
              <displayName>Master Mode Fault Flag</displayName>
              <description>Indicates a mode fault error in SPI master mode (e.g., NSS pulled low while configured as master). SPI is forced to slave mode if set. Cleared by read/write sequence.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_FAULT</name>
                  <displayName>No Fault</displayName>
                  <description>No master mode fault detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FAULT</name>
                  <displayName>Fault</displayName>
                  <description>Master mode fault occurred</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware if a mode fault condition arises in SPI master mode. Software checks it at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>OVRFLG</name>
              <displayName>Overrun Flag</displayName>
              <description>Indicates an overrun error occurred, typically when the received data is not read in time (SPI/I2S). Cleared by a read of SPI_DATA followed by a read of STS.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRUN</name>
                  <displayName>No Overrun</displayName>
                  <description>No unread data was overwritten</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OVERRUN</name>
                  <displayName>Overrun</displayName>
                  <description>Previously received data was lost due to not being read in time</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set at runtime by hardware when received data is overwritten. Software must check and clear it to handle the error.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BSYFLG</name>
              <displayName>Busy Flag</displayName>
              <description>Indicates that SPI/I2S is actively transmitting or receiving data.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <displayName>Idle</displayName>
                  <description>No current communication</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <displayName>Busy</displayName>
                  <description>SPI/I2S is transmitting or receiving data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware at runtime to indicate if communication is ongoing.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FFERR</name>
              <displayName>TI Frame Format Error Flag</displayName>
              <description>Indicates a frame format error in TI slave mode or a synchronization error in I2S slave mode. Cleared by reading STS.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_ERROR</name>
                  <displayName>No Error</displayName>
                  <description>No frame format error detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>Error</displayName>
                  <description>Frame format or synchronization error has been detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Hardware updates this flag at runtime if a TI or I2S frame error occurs. Software reads/clears it to detect synchronization loss.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>TXCRC</name>
          <displayName>SPI Transmit CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data transmitted in SPI mode. Its width matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>TXCRC</name>
              <displayName>Transmit Data CRC Value</displayName>
              <description>Holds the CRC result of the transmitted data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is continuously updated by hardware and read at runtime to verify the integrity of transmitted data (SPI CRC).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SPI4</name>
      <description>Serial peripheral interface</description>
      <groupName>SPI</groupName>
      <baseAddress>0x40013400</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
        <protection>n</protection>
      </addressBlock>
      <interrupt>
        <name>SPI4</name>
        <description>SPI4 global interrupt</description>
        <value>84</value>
      </interrupt>
      <registers>
        <register>
          <name>CRCPOLY</name>
          <displayName>SPI CRC Polynomial Register</displayName>
          <description>This register holds the CRC (Cyclic Redundancy Check) polynomial used for hardware-based CRC computations in SPI mode. Only the lower 16 bits are valid for defining the polynomial. This register is not used in I2S mode.</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x7</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CRCPOLY</name>
              <displayName>Cyclic Redundancy Check Polynomial Value</displayName>
              <description>This field specifies the polynomial for CRC computation (SPI mode only). When enabled via CRCEN, the hardware will use this polynomial to calculate and check the transmitted/received data. It is not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bitfield is typically configured once during SPI initialization to set the CRC polynomial.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <displayName>Serial Peripheral Interface Control Register 1</displayName>
          <description>This register is used to configure fundamental SPI parameters, including clock phase/polarity, master/slave selection, data frame format, and bidirectional mode settings. It is only used in SPI mode and not available when I2S mode is enabled.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CPHA</name>
              <displayName>Clock Phase</displayName>
              <description>Configures the clock phase used for data sampling; cannot be changed during an ongoing communication.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FIRST_EDGE</name>
                  <displayName>FIRST_EDGE</displayName>
                  <description>Data is sampled on the first clock edge (odd edge).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SECOND_EDGE</name>
                  <displayName>SECOND_EDGE</displayName>
                  <description>Data is sampled on the second clock edge (even edge).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit cannot be changed during an ongoing communication, so it's typically configured once at initialization.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Determines the idle state of the SCK line; cannot be changed during an ongoing communication.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>IDLE_LOW</displayName>
                  <description>SCK is low level in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>IDLE_HIGH</displayName>
                  <description>SCK is high level in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is also locked during communication, so it's typically set once before the SPI is enabled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MSMCFG</name>
              <displayName>Master/Slave Mode Config</displayName>
              <description>Selects master (MSMCFG=1) or slave (MSMCFG=0) mode operation; must be set before communication starts.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE</name>
                  <displayName>SLAVE</displayName>
                  <description>Device operates in slave mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER</name>
                  <displayName>MASTER</displayName>
                  <description>Device operates in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Mode selection must be done prior to communication and cannot change mid-transmission.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BRSEL</name>
              <displayName>Baud Rate Prescaler</displayName>
              <description>Sets the SPI clock prescaler, defining the baud rate as f_PCLK / (2^(BRSEL+1)) for these discrete options.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DIV2</name>
                  <displayName>DIV2</displayName>
                  <description>f_PCLK / 2</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV4</name>
                  <displayName>DIV4</displayName>
                  <description>f_PCLK / 4</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV8</name>
                  <displayName>DIV8</displayName>
                  <description>f_PCLK / 8</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV16</name>
                  <displayName>DIV16</displayName>
                  <description>f_PCLK / 16</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV32</name>
                  <displayName>DIV32</displayName>
                  <description>f_PCLK / 32</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV64</name>
                  <displayName>DIV64</displayName>
                  <description>f_PCLK / 64</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV128</name>
                  <displayName>DIV128</displayName>
                  <description>f_PCLK / 128</description>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV256</name>
                  <displayName>DIV256</displayName>
                  <description>f_PCLK / 256</description>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The baud rate prescaler cannot be changed on the fly; it's set beforehand.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SPIEN</name>
              <displayName>SPI Enable</displayName>
              <description>Enables or disables the SPI peripheral for communication.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SPI peripheral is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SPI peripheral is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is commonly toggled to start or stop SPI communication in normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>LSBSEL</name>
              <displayName>LSB First Select</displayName>
              <description>Determines whether data is transmitted with MSB-first or LSB-first ordering.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MSB_FIRST</name>
                  <displayName>MSB_FIRST</displayName>
                  <description>MSB is transmitted first.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_FIRST</name>
                  <displayName>LSB_FIRST</displayName>
                  <description>LSB is transmitted first.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically set once before communication starts; changing data order mid-communication is not advised.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ISSEL</name>
              <displayName>Internal NSS Level</displayName>
              <description>Sets the internal NSS level when software NSS mode is enabled.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NSS_LOW</name>
                  <displayName>NSS_LOW</displayName>
                  <description>Internal NSS is driven low.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NSS_HIGH</name>
                  <displayName>NSS_HIGH</displayName>
                  <description>Internal NSS is driven high.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>In software NSS mode, user code may toggle NSS at runtime to control slave selection.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSEN</name>
              <displayName>Software NSS Enable</displayName>
              <description>Enables or disables software slave management (SSM) for controlling NSS.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Software slave management disabled; external NSS is used.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Software slave management enabled; internal NSS is used.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically configured once depending on whether hardware or software NSS control is desired.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXOMEN</name>
              <displayName>Receive-Only Mode Enable</displayName>
              <description>Enables full-duplex (transmit/receive) or receive-only mode on the SPI lines.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FULL_DUPLEX</name>
                  <displayName>FULL_DUPLEX</displayName>
                  <description>Full-duplex transmit and receive.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RECEIVE_ONLY</name>
                  <displayName>RECEIVE_ONLY</displayName>
                  <description>Receive-only mode (MOSI is unused).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This determines whether SPI transmits data or not, typically set before enabling the peripheral.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DFLSEL</name>
              <displayName>Data Frame Format Select</displayName>
              <description>Selects either 8-bit or 16-bit data frame format for SPI transmissions.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_8</name>
                  <displayName>BIT_8</displayName>
                  <description>8-bit data frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>BIT_16</displayName>
                  <description>16-bit data frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length must be set before communication begins and cannot be changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCNXT</name>
              <displayName>CRC Transfer Next</displayName>
              <description>Indicates whether the next transmitted data is sourced from the TX buffer or the CRC register.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TX_BUFFER</name>
                  <displayName>TX_BUFFER</displayName>
                  <description>Next transmitted data is taken from the TX buffer.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CRC_REG</name>
                  <displayName>CRC_REGISTER</displayName>
                  <description>Next transmitted data is taken from the CRC register.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is used when appending CRC after sending all data, so it may be changed during normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEN</name>
              <displayName>CRC Calculation Enable</displayName>
              <description>Enables or disables the hardware-based CRC calculation for SPI in full-duplex mode.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>CRC calculation is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>CRC calculation is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Must be enabled or disabled prior to communication, typically only changed when SPI is not active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMOEN</name>
              <displayName>Bidirectional Mode Output Enable</displayName>
              <description>Selects output (TX-only) or input (RX-only) when in single-line bidirectional mode.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>INPUT</name>
                  <displayName>INPUT</displayName>
                  <description>Bidirectional line is used for input only.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OUTPUT</name>
                  <displayName>OUTPUT</displayName>
                  <description>Bidirectional line is used for output only.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Determines direction in single-line mode, set before the communication begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMEN</name>
              <displayName>Bidirectional Data Mode Enable</displayName>
              <description>Enables single-line bidirectional mode (BMEN=1) or two-line unidirectional mode (BMEN=0).</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TWO_LINE</name>
                  <displayName>TWO_LINE</displayName>
                  <description>Two-line unidirectional mode enabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIDIRECTIONAL</name>
                  <displayName>BIDIRECTIONAL</displayName>
                  <description>Single-line bidirectional mode enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Choosing single-line or two-line mode is a fundamental configuration done before enabling SPI.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL2</name>
          <displayName>Serial Peripheral Interface Control Register 2</displayName>
          <description>This register provides advanced control features for the SPI peripheral, such as enabling DMA requests, configuring the SS (NSS) output, selecting the SPI frame format (Motorola or TI mode) and enabling interrupts for various SPI-related events.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXDEN</name>
              <displayName>Receive DMA Enable</displayName>
              <description>Enables or disables the DMA request when the RX buffer is not empty.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for receive is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for receive is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how RX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXDEN</name>
              <displayName>Transmit DMA Enable</displayName>
              <description>Enables or disables the DMA request when the TX buffer is empty.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for transmit is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for transmit is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how TX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSOEN</name>
              <displayName>SS (NSS) Output Enable</displayName>
              <description>Enables or disables the SS (NSS) output when operating in master mode.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SS (NSS) output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SS (NSS) output is enabled in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Usually configured at initialization in master mode to determine if NSS is driven automatically.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FRFCFG</name>
              <displayName>Frame Format Configure</displayName>
              <description>Selects SPI Motorola mode (FRFCFG=0) or SPI TI mode (FRFCFG=1).</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MOTOROLA</name>
                  <displayName>MOTOROLA</displayName>
                  <description>SPI Motorola frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TI</name>
                  <displayName>TI</displayName>
                  <description>SPI TI frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Format is chosen prior to communication and isn't typically changed at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ERRIEN</name>
              <displayName>Error Interrupt Enable</displayName>
              <description>Enables or disables interrupts for SPI error flags (e.g., overrun or CRC errors).</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Error interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Error interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Error interrupts are usually enabled/disabled once in an initialization routine.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXBNEIEN</name>
              <displayName>RX Buffer Not Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the RX buffer becomes non-empty.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>RX buffer not empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>RX buffer not empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Interrupt usage is generally configured at initialization depending on the desired event handling.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEIEN</name>
              <displayName>TX Buffer Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the TX buffer becomes empty.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>TX buffer empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>TX buffer empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This interrupt is typically enabled or disabled once, according to whether TX events are needed.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <displayName>DATA</displayName>
          <description>data register</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>DATA</name>
              <displayName>Transmit/Receive Data</displayName>
              <description>Writes go to the transmit buffer; reads come from the receive buffer. For an 8-bit frame, only the lower 8 bits are used. For a 16-bit frame, all 16 bits are used.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This register is used continuously during operation to send and receive data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SCFG</name>
          <displayName>Inter-IC Sound (I2S) Configuration Register</displayName>
          <description>Configures the I2S parameters. This register is used only in I2S mode (not in SPI mode). Most bits can be written only when I2SEN=0 to avoid conflicts.</description>
          <addressOffset>0x1C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CHLEN</name>
              <displayName>Channel Length</displayName>
              <description>Selects the number of bits per audio channel. Must be greater than or equal to the data length. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>16-bit channel length</displayName>
                  <description>Each audio channel is 16 bits wide.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_32</name>
                  <displayName>32-bit channel length</displayName>
                  <description>Each audio channel is 32 bits wide.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Channel length is configured before enabling I2S and remains fixed during operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DATALEN</name>
              <displayName>Data Length</displayName>
              <description>Selects the data length for audio samples (16/24/32 bits). If data length is extended to 32 bits, the extra bits are forced to 0 or must be handled in two 16-bit accesses. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>16BIT</name>
                  <displayName>16-bit data length</displayName>
                  <description>Audio sample size is 16 bits.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>24BIT</name>
                  <displayName>24-bit data length</displayName>
                  <description>Audio sample size is 24 bits (two 16-bit accesses).</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>32BIT</name>
                  <displayName>32-bit data length</displayName>
                  <description>Audio sample size is 32 bits (two 16-bit accesses if using the 16-bit SPI_DATA register).</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Data length disabled</displayName>
                  <description>Not used; data length is disabled.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length is chosen at initialization and typically remains unchanged during I2S operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Selects the idle state (polarity) of the I2S clock line (CK). This bit can only be configured when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>Idle clock low</displayName>
                  <description>The clock line (CK) is low in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>Idle clock high</displayName>
                  <description>The clock line (CK) is high in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Idle clock polarity is selected prior to enabling I2S; not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SSSEL</name>
              <displayName>I2S Standard Selection</displayName>
              <description>Selects the audio standard: I2S Philips, MSB alignment, LSB alignment, or PCM. This bit can only be configured when I2SEN=0, and is not used in SPI mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>PHILIPS</name>
                  <displayName>I2S Philips standard</displayName>
                  <description>Uses the Philips I2S standard (WS toggles one bit before data).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MSB_ALIGN</name>
                  <displayName>MSB-alignment (left-justified)</displayName>
                  <description>Uses the MSB alignment standard.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_ALIGN</name>
                  <displayName>LSB-alignment (right-justified)</displayName>
                  <description>Uses the LSB alignment standard.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PCM</name>
                  <displayName>PCM standard</displayName>
                  <description>Uses the PCM short/long frame standard.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Audio protocol is configured before operation and remains unchanged once streaming begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>PFSSEL</name>
              <displayName>PCM Frame Sync Mode</displayName>
              <description>Selects short- or long-frame synchronization when PCM standard (I2SSSEL=11) is used. Not used for other standards. Can only be set when I2SEN=0.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SHORT</name>
                  <displayName>Short frame sync</displayName>
                  <description>Synchronization pulse is 1 bit wide (short frame).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LONG</name>
                  <displayName>Long frame sync</displayName>
                  <description>Synchronization pulse is 13 bits wide (long frame).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Frame sync size is a fundamental setup selected before I2S is enabled (only for PCM).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SMOD</name>
              <displayName>Master/Slave Transmit/Receive Mode</displayName>
              <description>Selects I2S master or slave, and TX or RX (So one of these four options: Slave Transmit, Slave Receive, Master Transmit or Master Receive). Can only be changed when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE_TX</name>
                  <displayName>Slave transmit</displayName>
                  <description>I2S operates as slave, transmitting data.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SLAVE_RX</name>
                  <displayName>Slave receive</displayName>
                  <description>I2S operates as slave, receiving data.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_TX</name>
                  <displayName>Master transmit</displayName>
                  <description>I2S operates as master, transmitting data.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_RX</name>
                  <displayName>Master receive</displayName>
                  <description>I2S operates as master, receiving data.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The master/slave role and TX/RX direction are configured before enabling the interface.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SEN</name>
              <displayName>I2S Enable</displayName>
              <description>Enables or disables the I2S module for audio communication. This bit can be toggled at runtime to start or stop I2S. All other configuration bits must be stable before enabling I2S.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>I2S disabled</displayName>
                  <description>The I2S module is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>I2S enabled</displayName>
                  <description>The I2S module is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Similar to SPIEN; can be set or cleared to enable/disable I2S at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MODESEL</name>
              <displayName>SPI/I2S Mode Select</displayName>
              <description>Selects whether the peripheral works in SPI mode or I2S mode. Must be set before enabling the peripheral; not allowed to change on the fly.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SPI</name>
                  <displayName>SPI mode</displayName>
                  <description>The peripheral operates in SPI mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>I2S</name>
                  <displayName>I2S mode</displayName>
                  <description>The peripheral operates in I2S mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This must be set before enabling the peripheral and cannot be changed once active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SPSC</name>
          <displayName>I2S (Inter-IC Sound) Prescaler Register</displayName>
          <description>The I2S prescaler register is used to configure the I2S clock prescaler to generate the correct audio sampling frequency. It is only valid in I2S mode (not used in SPI mode). The register must not be modified when the I2S is enabled (I2SEN=1). In particular, I2SPSC must not be set to 0 or 1.</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <!--
            According to the reference manual, the reset value is 0x0002 (0x2).
            This differs from the original SVD file, where the reset value was 0xA.
          -->
          <resetValue>0x0002</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>I2SPSC</name>
              <displayName>I2S Linear Prescaler</displayName>
              <description>Specifies the integer part of the I2S prescaler. Must not be 0 or 1. Can only be changed when I2SEN=0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This prescaler value is set before the I2S is enabled to define the desired audio sampling frequency.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ODDPSC</name>
              <displayName>Odd Prescaler Factor</displayName>
              <description>Determines whether the prescaler factor is multiplied by 2 or by (2 + 1). Can only be changed when I2SEN=0.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EVEN</name>
                  <displayName>EVEN</displayName>
                  <description>Prescaler factor = I2SPSC * 2.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ODD</name>
                  <displayName>ODD</displayName>
                  <description>Prescaler factor = (I2SPSC * 2) + 1.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Also a prescaler configuration bit that must be set before enabling I2S to achieve the correct audio clock.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MCOEN</name>
              <displayName>Master Clock Output Enable</displayName>
              <description>Enables or disables the extra master clock output pin in I2S master mode.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Master clock output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Master clock output is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is configured prior to operation if an external MCLK is needed. Not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>RXCRC</name>
          <displayName>SPI Receive CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data received in SPI mode. The width of this CRC matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXCRC</name>
              <displayName>Receive Data CRC Value</displayName>
              <description>Holds the CRC result of the received data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is updated at runtime by hardware (SPI CRC engine), and read at runtime to verify the integrity of received data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>STS</name>
          <displayName>SPI/I2S Status Register</displayName>
          <description>This register contains various status flags for SPI or I2S operation, such as buffer flags (transmit, receive), error flags (overrun, underrun, CRC error, mode fault, TI/I2S frame error), busy flag, and left/right channel indication.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0x2</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXBNEFLG</name>
              <displayName>Receive Buffer Not Empty Flag</displayName>
              <description>Indicates that the receive buffer contains valid data. In SPI mode, it is cleared by reading the SPI_DATA register. In I2S mode, it is cleared by reading the same data register.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The receive buffer is empty (no new data)</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The receive buffer contains valid data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to check if new data has been received.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEFLG</name>
              <displayName>Transmit Buffer Empty Flag</displayName>
              <description>Indicates that the transmit buffer is empty and can accept new data. In SPI/I2S mode, it is set by hardware after the data moves to the shift register.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The transmit buffer currently holds data</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The transmit buffer is empty and ready for new data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to know when it can write new data into the transmit buffer.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SCHDIR</name>
              <displayName>Sound Channel Direction</displayName>
              <description>Indicates whether the current data sample being transmitted or received belongs to the left or right audio channel (for I2S Philips/MSB/LSB modes). Not used in PCM standard.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEFT</name>
                  <displayName>Left Channel</displayName>
                  <description>Data is for the left audio channel</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RIGHT</name>
                  <displayName>Right Channel</displayName>
                  <description>Data is for the right audio channel</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware (based on WS signal) and read at runtime to identify which channel is active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>UDRFLG</name>
              <displayName>Underrun Flag</displayName>
              <description>Indicates an underrun error has occurred (mainly in I2S slave transmit mode) if the application fails to provide data in time.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_UNDERRUN</name>
                  <displayName>No Underrun</displayName>
                  <description>No underrun error occurred</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDERRUN</name>
                  <displayName>Underrun</displayName>
                  <description>Data was not written in time, causing an underrun</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware when the transmit buffer underruns. Software checks it at runtime to detect errors.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEFLG</name>
              <displayName>CRC Error Flag</displayName>
              <description>Indicates that the received CRC does not match the computed CRC in SPI mode. 0 = match (no CRC error), 1 = CRC error occurred. Cleared by writing 0 to this bit. Not used in I2S mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOERROR</name>
                  <displayName>No CRC Error</displayName>
                  <description>The received CRC matches the transmitted CRC</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>CRC Error</displayName>
                  <description>The CRC check failed</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is used at runtime to check if a SPI CRC mismatch has occurred. Cleared by writing 0.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MEFLG</name>
              <displayName>Master Mode Fault Flag</displayName>
              <description>Indicates a mode fault error in SPI master mode (e.g., NSS pulled low while configured as master). SPI is forced to slave mode if set. Cleared by read/write sequence.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_FAULT</name>
                  <displayName>No Fault</displayName>
                  <description>No master mode fault detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FAULT</name>
                  <displayName>Fault</displayName>
                  <description>Master mode fault occurred</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware if a mode fault condition arises in SPI master mode. Software checks it at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>OVRFLG</name>
              <displayName>Overrun Flag</displayName>
              <description>Indicates an overrun error occurred, typically when the received data is not read in time (SPI/I2S). Cleared by a read of SPI_DATA followed by a read of STS.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRUN</name>
                  <displayName>No Overrun</displayName>
                  <description>No unread data was overwritten</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OVERRUN</name>
                  <displayName>Overrun</displayName>
                  <description>Previously received data was lost due to not being read in time</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set at runtime by hardware when received data is overwritten. Software must check and clear it to handle the error.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BSYFLG</name>
              <displayName>Busy Flag</displayName>
              <description>Indicates that SPI/I2S is actively transmitting or receiving data.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <displayName>Idle</displayName>
                  <description>No current communication</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <displayName>Busy</displayName>
                  <description>SPI/I2S is transmitting or receiving data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware at runtime to indicate if communication is ongoing.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FFERR</name>
              <displayName>TI Frame Format Error Flag</displayName>
              <description>Indicates a frame format error in TI slave mode or a synchronization error in I2S slave mode. Cleared by reading STS.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_ERROR</name>
                  <displayName>No Error</displayName>
                  <description>No frame format error detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>Error</displayName>
                  <description>Frame format or synchronization error has been detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Hardware updates this flag at runtime if a TI or I2S frame error occurs. Software reads/clears it to detect synchronization loss.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>TXCRC</name>
          <displayName>SPI Transmit CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data transmitted in SPI mode. Its width matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>TXCRC</name>
              <displayName>Transmit Data CRC Value</displayName>
              <description>Holds the CRC result of the transmitted data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is continuously updated by hardware and read at runtime to verify the integrity of transmitted data (SPI CRC).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SPI5</name>
      <description>Serial peripheral interface</description>
      <groupName>SPI</groupName>
      <baseAddress>0x40015000</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
        <protection>n</protection>
      </addressBlock>
      <interrupt>
        <name>SPI5</name>
        <description>SPI5 global interrupt</description>
        <value>85</value>
      </interrupt>
      <registers>
        <register>
          <name>CRCPOLY</name>
          <displayName>SPI CRC Polynomial Register</displayName>
          <description>This register holds the CRC (Cyclic Redundancy Check) polynomial used for hardware-based CRC computations in SPI mode. Only the lower 16 bits are valid for defining the polynomial. This register is not used in I2S mode.</description>
          <addressOffset>0x10</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x7</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CRCPOLY</name>
              <displayName>Cyclic Redundancy Check Polynomial Value</displayName>
              <description>This field specifies the polynomial for CRC computation (SPI mode only). When enabled via CRCEN, the hardware will use this polynomial to calculate and check the transmitted/received data. It is not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bitfield is typically configured once during SPI initialization to set the CRC polynomial.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL1</name>
          <displayName>Serial Peripheral Interface Control Register 1</displayName>
          <description>This register is used to configure fundamental SPI parameters, including clock phase/polarity, master/slave selection, data frame format, and bidirectional mode settings. It is only used in SPI mode and not available when I2S mode is enabled.</description>
          <addressOffset>0x0</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CPHA</name>
              <displayName>Clock Phase</displayName>
              <description>Configures the clock phase used for data sampling; cannot be changed during an ongoing communication.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FIRST_EDGE</name>
                  <displayName>FIRST_EDGE</displayName>
                  <description>Data is sampled on the first clock edge (odd edge).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SECOND_EDGE</name>
                  <displayName>SECOND_EDGE</displayName>
                  <description>Data is sampled on the second clock edge (even edge).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit cannot be changed during an ongoing communication, so it's typically configured once at initialization.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Determines the idle state of the SCK line; cannot be changed during an ongoing communication.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>IDLE_LOW</displayName>
                  <description>SCK is low level in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>IDLE_HIGH</displayName>
                  <description>SCK is high level in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is also locked during communication, so it's typically set once before the SPI is enabled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MSMCFG</name>
              <displayName>Master/Slave Mode Config</displayName>
              <description>Selects master (MSMCFG=1) or slave (MSMCFG=0) mode operation; must be set before communication starts.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE</name>
                  <displayName>SLAVE</displayName>
                  <description>Device operates in slave mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER</name>
                  <displayName>MASTER</displayName>
                  <description>Device operates in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Mode selection must be done prior to communication and cannot change mid-transmission.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BRSEL</name>
              <displayName>Baud Rate Prescaler</displayName>
              <description>Sets the SPI clock prescaler, defining the baud rate as f_PCLK / (2^(BRSEL+1)) for these discrete options.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>3</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DIV2</name>
                  <displayName>DIV2</displayName>
                  <description>f_PCLK / 2</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV4</name>
                  <displayName>DIV4</displayName>
                  <description>f_PCLK / 4</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV8</name>
                  <displayName>DIV8</displayName>
                  <description>f_PCLK / 8</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV16</name>
                  <displayName>DIV16</displayName>
                  <description>f_PCLK / 16</description>
                  <value>3</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV32</name>
                  <displayName>DIV32</displayName>
                  <description>f_PCLK / 32</description>
                  <value>4</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV64</name>
                  <displayName>DIV64</displayName>
                  <description>f_PCLK / 64</description>
                  <value>5</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV128</name>
                  <displayName>DIV128</displayName>
                  <description>f_PCLK / 128</description>
                  <value>6</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DIV256</name>
                  <displayName>DIV256</displayName>
                  <description>f_PCLK / 256</description>
                  <value>7</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The baud rate prescaler cannot be changed on the fly; it's set beforehand.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SPIEN</name>
              <displayName>SPI Enable</displayName>
              <description>Enables or disables the SPI peripheral for communication.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SPI peripheral is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SPI peripheral is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This bit is commonly toggled to start or stop SPI communication in normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>LSBSEL</name>
              <displayName>LSB First Select</displayName>
              <description>Determines whether data is transmitted with MSB-first or LSB-first ordering.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MSB_FIRST</name>
                  <displayName>MSB_FIRST</displayName>
                  <description>MSB is transmitted first.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_FIRST</name>
                  <displayName>LSB_FIRST</displayName>
                  <description>LSB is transmitted first.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically set once before communication starts; changing data order mid-communication is not advised.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ISSEL</name>
              <displayName>Internal NSS Level</displayName>
              <description>Sets the internal NSS level when software NSS mode is enabled.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NSS_LOW</name>
                  <displayName>NSS_LOW</displayName>
                  <description>Internal NSS is driven low.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NSS_HIGH</name>
                  <displayName>NSS_HIGH</displayName>
                  <description>Internal NSS is driven high.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>In software NSS mode, user code may toggle NSS at runtime to control slave selection.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSEN</name>
              <displayName>Software NSS Enable</displayName>
              <description>Enables or disables software slave management (SSM) for controlling NSS.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Software slave management disabled; external NSS is used.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Software slave management enabled; internal NSS is used.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically configured once depending on whether hardware or software NSS control is desired.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXOMEN</name>
              <displayName>Receive-Only Mode Enable</displayName>
              <description>Enables full-duplex (transmit/receive) or receive-only mode on the SPI lines.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>FULL_DUPLEX</name>
                  <displayName>FULL_DUPLEX</displayName>
                  <description>Full-duplex transmit and receive.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RECEIVE_ONLY</name>
                  <displayName>RECEIVE_ONLY</displayName>
                  <description>Receive-only mode (MOSI is unused).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This determines whether SPI transmits data or not, typically set before enabling the peripheral.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DFLSEL</name>
              <displayName>Data Frame Format Select</displayName>
              <description>Selects either 8-bit or 16-bit data frame format for SPI transmissions.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_8</name>
                  <displayName>BIT_8</displayName>
                  <description>8-bit data frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>BIT_16</displayName>
                  <description>16-bit data frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length must be set before communication begins and cannot be changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCNXT</name>
              <displayName>CRC Transfer Next</displayName>
              <description>Indicates whether the next transmitted data is sourced from the TX buffer or the CRC register.</description>
              <bitOffset>12</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TX_BUFFER</name>
                  <displayName>TX_BUFFER</displayName>
                  <description>Next transmitted data is taken from the TX buffer.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>CRC_REG</name>
                  <displayName>CRC_REGISTER</displayName>
                  <description>Next transmitted data is taken from the CRC register.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is used when appending CRC after sending all data, so it may be changed during normal operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEN</name>
              <displayName>CRC Calculation Enable</displayName>
              <description>Enables or disables the hardware-based CRC calculation for SPI in full-duplex mode.</description>
              <bitOffset>13</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>CRC calculation is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>CRC calculation is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Must be enabled or disabled prior to communication, typically only changed when SPI is not active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMOEN</name>
              <displayName>Bidirectional Mode Output Enable</displayName>
              <description>Selects output (TX-only) or input (RX-only) when in single-line bidirectional mode.</description>
              <bitOffset>14</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>INPUT</name>
                  <displayName>INPUT</displayName>
                  <description>Bidirectional line is used for input only.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OUTPUT</name>
                  <displayName>OUTPUT</displayName>
                  <description>Bidirectional line is used for output only.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Determines direction in single-line mode, set before the communication begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BMEN</name>
              <displayName>Bidirectional Data Mode Enable</displayName>
              <description>Enables single-line bidirectional mode (BMEN=1) or two-line unidirectional mode (BMEN=0).</description>
              <bitOffset>15</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>TWO_LINE</name>
                  <displayName>TWO_LINE</displayName>
                  <description>Two-line unidirectional mode enabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIDIRECTIONAL</name>
                  <displayName>BIDIRECTIONAL</displayName>
                  <description>Single-line bidirectional mode enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Choosing single-line or two-line mode is a fundamental configuration done before enabling SPI.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>CTRL2</name>
          <displayName>Serial Peripheral Interface Control Register 2</displayName>
          <description>This register provides advanced control features for the SPI peripheral, such as enabling DMA requests, configuring the SS (NSS) output, selecting the SPI frame format (Motorola or TI mode) and enabling interrupts for various SPI-related events.</description>
          <addressOffset>0x4</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXDEN</name>
              <displayName>Receive DMA Enable</displayName>
              <description>Enables or disables the DMA request when the RX buffer is not empty.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for receive is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for receive is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how RX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXDEN</name>
              <displayName>Transmit DMA Enable</displayName>
              <description>Enables or disables the DMA request when the TX buffer is empty.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>DMA request for transmit is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>DMA request for transmit is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Typically enabled/disabled once during initialization to define how TX data is handled.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SSOEN</name>
              <displayName>SS (NSS) Output Enable</displayName>
              <description>Enables or disables the SS (NSS) output when operating in master mode.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>SS (NSS) output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>SS (NSS) output is enabled in master mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Usually configured at initialization in master mode to determine if NSS is driven automatically.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FRFCFG</name>
              <displayName>Frame Format Configure</displayName>
              <description>Selects SPI Motorola mode (FRFCFG=0) or SPI TI mode (FRFCFG=1).</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>MOTOROLA</name>
                  <displayName>MOTOROLA</displayName>
                  <description>SPI Motorola frame format.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TI</name>
                  <displayName>TI</displayName>
                  <description>SPI TI frame format.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Format is chosen prior to communication and isn't typically changed at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ERRIEN</name>
              <displayName>Error Interrupt Enable</displayName>
              <description>Enables or disables interrupts for SPI error flags (e.g., overrun or CRC errors).</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Error interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Error interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Error interrupts are usually enabled/disabled once in an initialization routine.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>RXBNEIEN</name>
              <displayName>RX Buffer Not Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the RX buffer becomes non-empty.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>RX buffer not empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>RX buffer not empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Interrupt usage is generally configured at initialization depending on the desired event handling.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEIEN</name>
              <displayName>TX Buffer Empty Interrupt Enable</displayName>
              <description>Enables or disables the interrupt when the TX buffer becomes empty.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>TX buffer empty interrupt disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>TX buffer empty interrupt enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This interrupt is typically enabled or disabled once, according to whether TX events are needed.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>DATA</name>
          <displayName>DATA</displayName>
          <description>data register</description>
          <addressOffset>0xC</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>DATA</name>
              <displayName>Transmit/Receive Data</displayName>
              <description>Writes go to the transmit buffer; reads come from the receive buffer. For an 8-bit frame, only the lower 8 bits are used. For a 16-bit frame, all 16 bits are used.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This register is used continuously during operation to send and receive data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SCFG</name>
          <displayName>Inter-IC Sound (I2S) Configuration Register</displayName>
          <description>Configures the I2S parameters. This register is used only in I2S mode (not in SPI mode). Most bits can be written only when I2SEN=0 to avoid conflicts.</description>
          <addressOffset>0x1C</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CHLEN</name>
              <displayName>Channel Length</displayName>
              <description>Selects the number of bits per audio channel. Must be greater than or equal to the data length. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>BIT_16</name>
                  <displayName>16-bit channel length</displayName>
                  <description>Each audio channel is 16 bits wide.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BIT_32</name>
                  <displayName>32-bit channel length</displayName>
                  <description>Each audio channel is 32 bits wide.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Channel length is configured before enabling I2S and remains fixed during operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>DATALEN</name>
              <displayName>Data Length</displayName>
              <description>Selects the data length for audio samples (16/24/32 bits). If data length is extended to 32 bits, the extra bits are forced to 0 or must be handled in two 16-bit accesses. Only valid in I2S mode and can be changed only when I2S is disabled (I2SEN=0).</description>
              <bitOffset>1</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>16BIT</name>
                  <displayName>16-bit data length</displayName>
                  <description>Audio sample size is 16 bits.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>24BIT</name>
                  <displayName>24-bit data length</displayName>
                  <description>Audio sample size is 24 bits (two 16-bit accesses).</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>32BIT</name>
                  <displayName>32-bit data length</displayName>
                  <description>Audio sample size is 32 bits (two 16-bit accesses if using the 16-bit SPI_DATA register).</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>Data length disabled</displayName>
                  <description>Not used; data length is disabled.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Data length is chosen at initialization and typically remains unchanged during I2S operation.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Selects the idle state (polarity) of the I2S clock line (CK). This bit can only be configured when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE_LOW</name>
                  <displayName>Idle clock low</displayName>
                  <description>The clock line (CK) is low in idle state.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>IDLE_HIGH</name>
                  <displayName>Idle clock high</displayName>
                  <description>The clock line (CK) is high in idle state.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Idle clock polarity is selected prior to enabling I2S; not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SSSEL</name>
              <displayName>I2S Standard Selection</displayName>
              <description>Selects the audio standard: I2S Philips, MSB alignment, LSB alignment, or PCM. This bit can only be configured when I2SEN=0, and is not used in SPI mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>PHILIPS</name>
                  <displayName>I2S Philips standard</displayName>
                  <description>Uses the Philips I2S standard (WS toggles one bit before data).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MSB_ALIGN</name>
                  <displayName>MSB-alignment (left-justified)</displayName>
                  <description>Uses the MSB alignment standard.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LSB_ALIGN</name>
                  <displayName>LSB-alignment (right-justified)</displayName>
                  <description>Uses the LSB alignment standard.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>PCM</name>
                  <displayName>PCM standard</displayName>
                  <description>Uses the PCM short/long frame standard.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Audio protocol is configured before operation and remains unchanged once streaming begins.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>PFSSEL</name>
              <displayName>PCM Frame Sync Mode</displayName>
              <description>Selects short- or long-frame synchronization when PCM standard (I2SSSEL=11) is used. Not used for other standards. Can only be set when I2SEN=0.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SHORT</name>
                  <displayName>Short frame sync</displayName>
                  <description>Synchronization pulse is 1 bit wide (short frame).</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>LONG</name>
                  <displayName>Long frame sync</displayName>
                  <description>Synchronization pulse is 13 bits wide (long frame).</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Frame sync size is a fundamental setup selected before I2S is enabled (only for PCM).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SMOD</name>
              <displayName>Master/Slave Transmit/Receive Mode</displayName>
              <description>Selects I2S master or slave, and TX or RX (So one of these four options: Slave Transmit, Slave Receive, Master Transmit or Master Receive). Can only be changed when I2SEN=0. Not used in SPI mode.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SLAVE_TX</name>
                  <displayName>Slave transmit</displayName>
                  <description>I2S operates as slave, transmitting data.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>SLAVE_RX</name>
                  <displayName>Slave receive</displayName>
                  <description>I2S operates as slave, receiving data.</description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_TX</name>
                  <displayName>Master transmit</displayName>
                  <description>I2S operates as master, transmitting data.</description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>MASTER_RX</name>
                  <displayName>Master receive</displayName>
                  <description>I2S operates as master, receiving data.</description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>The master/slave role and TX/RX direction are configured before enabling the interface.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>I2SEN</name>
              <displayName>I2S Enable</displayName>
              <description>Enables or disables the I2S module for audio communication. This bit can be toggled at runtime to start or stop I2S. All other configuration bits must be stable before enabling I2S.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>I2S disabled</displayName>
                  <description>The I2S module is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>I2S enabled</displayName>
                  <description>The I2S module is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Similar to SPIEN; can be set or cleared to enable/disable I2S at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MODESEL</name>
              <displayName>SPI/I2S Mode Select</displayName>
              <description>Selects whether the peripheral works in SPI mode or I2S mode. Must be set before enabling the peripheral; not allowed to change on the fly.</description>
              <bitOffset>11</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>SPI</name>
                  <displayName>SPI mode</displayName>
                  <description>The peripheral operates in SPI mode.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>I2S</name>
                  <displayName>I2S mode</displayName>
                  <description>The peripheral operates in I2S mode.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This must be set before enabling the peripheral and cannot be changed once active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>I2SPSC</name>
          <displayName>I2S (Inter-IC Sound) Prescaler Register</displayName>
          <description>The I2S prescaler register is used to configure the I2S clock prescaler to generate the correct audio sampling frequency. It is only valid in I2S mode (not used in SPI mode). The register must not be modified when the I2S is enabled (I2SEN=1). In particular, I2SPSC must not be set to 0 or 1.</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <!--
            According to the reference manual, the reset value is 0x0002 (0x2).
            This differs from the original SVD file, where the reset value was 0xA.
          -->
          <resetValue>0x0002</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>I2SPSC</name>
              <displayName>I2S Linear Prescaler</displayName>
              <description>Specifies the integer part of the I2S prescaler. Must not be 0 or 1. Can only be changed when I2SEN=0.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>8</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This prescaler value is set before the I2S is enabled to define the desired audio sampling frequency.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>ODDPSC</name>
              <displayName>Odd Prescaler Factor</displayName>
              <description>Determines whether the prescaler factor is multiplied by 2 or by (2 + 1). Can only be changed when I2SEN=0.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EVEN</name>
                  <displayName>EVEN</displayName>
                  <description>Prescaler factor = I2SPSC * 2.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ODD</name>
                  <displayName>ODD</displayName>
                  <description>Prescaler factor = (I2SPSC * 2) + 1.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Also a prescaler configuration bit that must be set before enabling I2S to achieve the correct audio clock.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MCOEN</name>
              <displayName>Master Clock Output Enable</displayName>
              <description>Enables or disables the extra master clock output pin in I2S master mode.</description>
              <bitOffset>9</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLE</name>
                  <displayName>DISABLE</displayName>
                  <description>Master clock output is disabled.</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLE</name>
                  <displayName>ENABLE</displayName>
                  <description>Master clock output is enabled.</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This is configured prior to operation if an external MCLK is needed. Not typically changed on the fly.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>RXCRC</name>
          <displayName>SPI Receive CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data received in SPI mode. The width of this CRC matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x14</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXCRC</name>
              <displayName>Receive Data CRC Value</displayName>
              <description>Holds the CRC result of the received data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is updated at runtime by hardware (SPI CRC engine), and read at runtime to verify the integrity of received data.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>STS</name>
          <displayName>SPI/I2S Status Register</displayName>
          <description>This register contains various status flags for SPI or I2S operation, such as buffer flags (transmit, receive), error flags (overrun, underrun, CRC error, mode fault, TI/I2S frame error), busy flag, and left/right channel indication.</description>
          <addressOffset>0x8</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0x2</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>RXBNEFLG</name>
              <displayName>Receive Buffer Not Empty Flag</displayName>
              <description>Indicates that the receive buffer contains valid data. In SPI mode, it is cleared by reading the SPI_DATA register. In I2S mode, it is cleared by reading the same data register.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The receive buffer is empty (no new data)</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The receive buffer contains valid data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to check if new data has been received.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXBEFLG</name>
              <displayName>Transmit Buffer Empty Flag</displayName>
              <description>Indicates that the transmit buffer is empty and can accept new data. In SPI/I2S mode, it is set by hardware after the data moves to the shift register.</description>
              <bitOffset>1</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOTEMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>The transmit buffer currently holds data</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>The transmit buffer is empty and ready for new data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is continuously updated by hardware and read by software during runtime to know when it can write new data into the transmit buffer.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>SCHDIR</name>
              <displayName>Sound Channel Direction</displayName>
              <description>Indicates whether the current data sample being transmitted or received belongs to the left or right audio channel (for I2S Philips/MSB/LSB modes). Not used in PCM standard.</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>LEFT</name>
                  <displayName>Left Channel</displayName>
                  <description>Data is for the left audio channel</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>RIGHT</name>
                  <displayName>Right Channel</displayName>
                  <description>Data is for the right audio channel</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware (based on WS signal) and read at runtime to identify which channel is active.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>UDRFLG</name>
              <displayName>Underrun Flag</displayName>
              <description>Indicates an underrun error has occurred (mainly in I2S slave transmit mode) if the application fails to provide data in time.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_UNDERRUN</name>
                  <displayName>No Underrun</displayName>
                  <description>No underrun error occurred</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>UNDERRUN</name>
                  <displayName>Underrun</displayName>
                  <description>Data was not written in time, causing an underrun</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware when the transmit buffer underruns. Software checks it at runtime to detect errors.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>CRCEFLG</name>
              <displayName>CRC Error Flag</displayName>
              <description>Indicates that the received CRC does not match the computed CRC in SPI mode. 0 = match (no CRC error), 1 = CRC error occurred. Cleared by writing 0 to this bit. Not used in I2S mode.</description>
              <bitOffset>4</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOERROR</name>
                  <displayName>No CRC Error</displayName>
                  <description>The received CRC matches the transmitted CRC</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>CRC Error</displayName>
                  <description>The CRC check failed</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is used at runtime to check if a SPI CRC mismatch has occurred. Cleared by writing 0.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>MEFLG</name>
              <displayName>Master Mode Fault Flag</displayName>
              <description>Indicates a mode fault error in SPI master mode (e.g., NSS pulled low while configured as master). SPI is forced to slave mode if set. Cleared by read/write sequence.</description>
              <bitOffset>5</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_FAULT</name>
                  <displayName>No Fault</displayName>
                  <description>No master mode fault detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FAULT</name>
                  <displayName>Fault</displayName>
                  <description>Master mode fault occurred</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set by hardware if a mode fault condition arises in SPI master mode. Software checks it at runtime.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>OVRFLG</name>
              <displayName>Overrun Flag</displayName>
              <description>Indicates an overrun error occurred, typically when the received data is not read in time (SPI/I2S). Cleared by a read of SPI_DATA followed by a read of STS.</description>
              <bitOffset>6</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_OVERRUN</name>
                  <displayName>No Overrun</displayName>
                  <description>No unread data was overwritten</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>OVERRUN</name>
                  <displayName>Overrun</displayName>
                  <description>Previously received data was lost due to not being read in time</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is set at runtime by hardware when received data is overwritten. Software must check and clear it to handle the error.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>BSYFLG</name>
              <displayName>Busy Flag</displayName>
              <description>Indicates that SPI/I2S is actively transmitting or receiving data.</description>
              <bitOffset>7</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>IDLE</name>
                  <displayName>Idle</displayName>
                  <description>No current communication</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>BUSY</name>
                  <displayName>Busy</displayName>
                  <description>SPI/I2S is transmitting or receiving data</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This flag is updated by hardware at runtime to indicate if communication is ongoing.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>FFERR</name>
              <displayName>TI Frame Format Error Flag</displayName>
              <description>Indicates a frame format error in TI slave mode or a synchronization error in I2S slave mode. Cleared by reading STS.</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_ERROR</name>
                  <displayName>No Error</displayName>
                  <description>No frame format error detected</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ERROR</name>
                  <displayName>Error</displayName>
                  <description>Frame format or synchronization error has been detected</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Hardware updates this flag at runtime if a TI or I2S frame error occurs. Software reads/clears it to detect synchronization loss.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>TXCRC</name>
          <displayName>SPI Transmit CRC Register</displayName>
          <description>This register stores the hardware-calculated CRC of the data transmitted in SPI mode. Its width matches the SPI data frame width (CRC8 if 8 bits, CRC16 if 16 bits). It is cleared by hardware when the CRCEN bit in SPI_CTRL1 is set. Not used in I2S mode. If the BSYFLG bit is set, reading this register may yield invalid data.</description>
          <addressOffset>0x18</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>TXCRC</name>
              <displayName>Transmit Data CRC Value</displayName>
              <description>Holds the CRC result of the transmitted data in SPI mode. The field width follows the configured data frame. Cleared by hardware when CRCEN is set. Not used in I2S mode.</description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This field is continuously updated by hardware and read at runtime to verify the integrity of transmitted data (SPI CRC).</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
      </registers>
    </peripheral>
    <peripheral>
      <name>SYSCFG</name>
      <description>System configuration controller</description>
      <groupName>SYSCFG</groupName>
      <baseAddress>0x40013800</baseAddress>
      <addressBlock>
        <offset>0x0</offset>
        <size>0x400</size>
        <usage>registers</usage>
        <protection>n</protection>
      </addressBlock>
      <registers>
        <register>
          <name>CCCTRL</name>
          <displayName>CCCTRL</displayName>
          <description>Compensation cell control register</description>
          <addressOffset>0x20</addressOffset>
          <size>32</size>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>CCPD</name>
              <description>Compensation Cell Power-down</description>
              <bitOffset>0</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
            </field>
            <field>
              <name>EDYFLG</name>
              <description>Compensation Cell Ready Flag</description>
              <bitOffset>8</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
            </field>
          </fields>
        </register>
        <register>
          <name>EINTCFG1</name>
          <displayName>EINTCFG1</displayName>
          <description>external interrupt configuration register 1</description>
          <addressOffset>0x8</addressOffset>
