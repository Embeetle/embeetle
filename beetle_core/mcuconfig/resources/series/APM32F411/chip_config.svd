        <register>
          <name>INJSEQ</name>
          <displayName>ADC Injected Sequence Register</displayName>
          <description>
            Configures the injected channels sequence and the total number of injected
            conversions (sequence length).
          </description>
          <addressOffset>0x38</addressOffset>
          <size>32</size>
          <access>read-write</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>INJSEQC1</name>
              <displayName>Injected Sequence Channel 1</displayName>
              <description>
                Channel number for the 1st conversion in the injected sequence.
                Valid range: 0-17 (external or internal ADC channels).
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured during initialization to select which channel is converted
                  first in the injected sequence (if sequence length >= 4).
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJSEQC2</name>
              <displayName>Injected Sequence Channel 2</displayName>
              <description>
                Channel number for the 2nd conversion in the injected sequence.
                Valid range: 0-17 (external or internal ADC channels).
              </description>
              <bitOffset>5</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured during initialization to select which channel is converted
                  second in the injected sequence (if sequence length >= 3).
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJSEQC3</name>
              <displayName>Injected Sequence Channel 3</displayName>
              <description>
                Channel number for the 3rd conversion in the injected sequence.
                Valid range: 0-17 (external or internal ADC channels).
              </description>
              <bitOffset>10</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured during initialization to select which channel is converted
                  third in the injected sequence (if sequence length >= 2).
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJSEQC4</name>
              <displayName>Injected Sequence Channel 4</displayName>
              <description>
                Channel number for the 4th conversion in the injected sequence.
                Valid range: 0-17 (external or internal ADC channels).
              </description>
              <bitOffset>15</bitOffset>
              <bitWidth>5</bitWidth>
              <access>read-write</access>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Configured during initialization to select which channel is converted
                  fourth in the injected sequence (if sequence length >= 1).
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>INJSEQLEN</name>
              <displayName>Injected Sequence Length</displayName>
              <description>
                Specifies how many conversions are performed in the injected sequence.
              </description>
              <bitOffset>20</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>ONE</name>
                  <displayName>1 Conversion</displayName>
                  <description>
                    Sequence performs only 1 conversion: INJSEQ4
                  </description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>TWO</name>
                  <displayName>2 Conversions</displayName>
                  <description>
                    Sequence performs INJSEQ3 → INJSEQ4
                  </description>
                  <value>1</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>THREE</name>
                  <displayName>3 Conversions</displayName>
                  <description>
                    Sequence performs INJSEQ2 → INJSEQ3 → INJSEQ4
                  </description>
                  <value>2</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>FOUR</name>
                  <displayName>4 Conversions</displayName>
                  <description>
                    Sequence performs INJSEQ1 → INJSEQ2 → INJSEQ3 → INJSEQ4
                  </description>
                  <value>3</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Set during initialization to define how many injected 
                  conversions occur and in which order.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
        <register>
          <name>REGDATA</name>
          <displayName>ADC Regular Data Register</displayName>
          <description>
            Holds the conversion data of the regular channels. In single-ADC mode, only
            the lower 16 bits are used for the ADC data. In dual-ADC mode, the upper
            16 bits store the conversion data of the second ADC.
          </description>
          <addressOffset>0x4C</addressOffset>
          <size>32</size>
          <access>read-only</access>
          <protection>n</protection>
          <resetValue>0x0</resetValue>
          <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>REGDATA</name>
              <displayName>Regular Data</displayName>
              <description>
                Conversion result of the regular channel(s). In single-ADC mode, bits
                [15:0] hold the ADC data. In dual-ADC mode, bits [15:0] hold ADC1 data
                and bits [31:16] hold ADC2 data.
              </description>
              <bitOffset>0</bitOffset>
              <bitWidth>16</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>
                  Read at runtime to obtain the most recent result from the 
                  regular channel(s). In dual-ADC mode, additional data is 
                  stored in the upper 16 bits.
                </embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
          </fields>
        </register>
