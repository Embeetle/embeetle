              <description>Software sets this bit to abort a pending transmit request in mailbox 2. Cleared by hardware when no message is waiting or after successful abort.</description>
              <bitOffset>23</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NO_ABORT</name>
                  <displayName>No Abort</displayName>
                  <description>No abort request</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ABORT</name>
                  <displayName>Abort</displayName>
                  <description>Abort the current transmit request</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Abort is typically triggered at runtime if needed.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>EMNUM</name>
              <displayName>Empty Mailbox Number</displayName>
              <description>Indicates the index of an empty mailbox or the next mailbox to be transmitted if not all are empty.</description>
              <bitOffset>24</bitOffset>
              <bitWidth>2</bitWidth>
              <access>read-only</access>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>This read-only field is checked at runtime to find or track the next available mailbox.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXMEFLG0</name>
              <displayName>Transmit Mailbox 0 Empty Flag</displayName>
              <description>Set by hardware when mailbox 0 is empty. Cleared by hardware when a message is pending.</description>
              <bitOffset>26</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-only</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>NOT_EMPTY</name>
                  <displayName>Not Empty</displayName>
                  <description>Message pending in mailbox 0</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>EMPTY</name>
                  <displayName>Empty</displayName>
                  <description>Mailbox 0 contains no message</description>
                  <value>1</value>
                </enumeratedValue>
              </enumeratedValues>
              <vendorExtensions>
                <embeetle:fieldKind>runtime</embeetle:fieldKind>
                <embeetle:fieldKindCmt>Used at runtime to check mailbox 0 availability.</embeetle:fieldKindCmt>
              </vendorExtensions>
            </field>
            <field>
              <name>TXMEFLG1</name>
              <displayName>Transmit Mailbox 1 Empty Flag</displayName>
