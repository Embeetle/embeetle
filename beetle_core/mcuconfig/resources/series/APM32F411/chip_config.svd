        <register>
          <name>TXDLEN0</name>
          <displayName>CAN Transmit Mailbox Data Length Register 0</displayName>
          <description>
            This register holds the data length code (DLC) for the message to be transmitted from mailbox 0. When the mailbox is not idle,
            all bits of this register are write-protected. A maximum of 8 data bytes is supported.
          </description>
          <addressOffset>0x184</addressOffset>
