              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>TXCIEN</name>
              <displayName>Transmission Complete Interrupt Enable</displayName>
