              <vendorExtensions>
                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>CPOL</name>
              <displayName>Clock Polarity</displayName>
              <description>Sets the state of the CK pin when the USART is idle in synchronous mode. This bit does not exist on UART4 or UART5.</description>
              <bitOffset>10</bitOffset>
              <bitWidth>1</bitWidth>
