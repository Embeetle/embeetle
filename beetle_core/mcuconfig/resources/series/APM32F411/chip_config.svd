                <embeetle:fieldKind>setting</embeetle:fieldKind>
              </vendorExtensions>
            </field>
            <field>
              <name>HDEN</name>
              <displayName>Half-duplex Mode Enable</displayName>
              <description>HDEN bit of USART_CTRL3 register determines whether to enter the single-line half-duplex mode.</description>
              <bitOffset>3</bitOffset>
              <bitWidth>1</bitWidth>
              <access>read-write</access>
              <enumeratedValues>
                <enumeratedValue>
                  <name>DISABLED</name>
                  <description>Half-duplex mode disabled</description>
                  <value>0</value>
                </enumeratedValue>
                <enumeratedValue>
                  <name>ENABLED</name>
