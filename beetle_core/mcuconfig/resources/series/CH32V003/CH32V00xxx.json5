//================================================================================================//
//                                       CH32V00xxx SERIES                                        //
//================================================================================================//
{
  "series": "CH32V00xxx",

  //----------------------------------------------------------------------------------------------//
  //                                       PIN ASSIGNMENTS                                        //
  //----------------------------------------------------------------------------------------------//
  // All settings related to the PIN VIEW in Embeetle

  //-----------------------------------//
  //             1. PARTS              //
  //-----------------------------------//
  // The 'PARTS' are the components you can buy. A 'SERIES' groups all the parts that are based on
  // the exact same silicon chip, but have different packages and internal wirebonding (they can
  // also differ in flash and buffer sizes). Below we list all the parts that belong to the series
  // from this json-file.
  // Notice the "wirebonding-layout" field for each part. It *usually* is just the package name. If
  // two parts with the same package have a different wirebonding, then this field would add a
  // suffix to the package name, for example: "LQFP100-1", "LQFP100-2".
  "parts": [
    {
      "name":               "CH32V003A4M6",
      "package":            "SOP16",
      "wirebonding-layout": "SOP16"
    },
    {
      "name":               "CH32V003F4P6",
      "package":            "TSSOP20",
      "wirebonding-layout": "TSSOP20"
    },
    {
      "name":               "CH32V003F4U6",
      "package":            "QFN20",
      "wirebonding-layout": "QFN20"
    },
    {
      "name":               "CH32V003J4M6",
      "package":            "SOP8",
      "wirebonding-layout": "SOP8"
    }
  ],

  //-----------------------------------//
  //              2. PINS              //
  //-----------------------------------//
  // The PINS section consists of:
  //   - "wirebonding-layout" and "wirebonding"
  //   - "types"
  //   - "modes"
  //   - "config"
  //   - "map"
  "pins": {

    // 2.1 WIREBONDING
    // ---------------
    // The "wirebonding-layout" field lists all the wirebonding layouts. Their order is important
    // for the wirebonding matrix that follows.
    "wirebonding-layout":                    ["SOP16","TSSOP20","QFN20","SOP8"],

    // The "wirebonding" field contains a matrix to specify the wirebonding between the PADS and
    // PINS. In this matrix, you can check for each pad to which pin it is bonded for a given
    // wirebonding layout.
    // For each pad, the "type" is also given. What these types mean is for the next chapter.
    "wirebonding": [
      {"pad": "PD4", "type": "I/O/A",  "pins": [    8,        1,     18,    8 ]},
      {"pad": "PD5", "type": "I/O/A",  "pins": [    9,        2,     19,    8 ]},
      {"pad": "PD6", "type": "I/O/A",  "pins": [   10,        3,     20,    1 ]},
      {"pad": "PD7", "type": "I/O/A",  "pins": [   11,        4,      1, null ]},
      {"pad": "PA1", "type": "I/O/A",  "pins": [   12,        5,      2,    1 ]},
      {"pad": "PA2", "type": "I/O/A",  "pins": [   13,        6,      3,    3 ]},
      {"pad": "VSS", "type": "P",      "pins": [   14,        7,      4,    2 ]},
      {"pad": "PD0", "type": "I/O/A",  "pins": [ null,        8,      5, null ]},
      {"pad": "VDD", "type": "P",      "pins": [   15,        9,      6,    4 ]},
      {"pad": "PC0", "type": "I/O",    "pins": [   16,       10,      7, null ]},
      {"pad": "PC1", "type": "I/O/FT", "pins": [    1,       11,      8,    5 ]},
      {"pad": "PC2", "type": "I/O/FT", "pins": [    2,       12,      9,    6 ]},
      {"pad": "PC3", "type": "I/O",    "pins": [    3,       13,     10, null ]},
      {"pad": "PC4", "type": "I/O/A",  "pins": [    4,       14,     11,    7 ]},
      {"pad": "PC5", "type": "I/O/FT", "pins": [ null,       15,     12, null ]},
      {"pad": "PC6", "type": "I/O/FT", "pins": [    5,       16,     13, null ]},
      {"pad": "PC7", "type": "I/O",    "pins": [    6,       17,     14, null ]},
      {"pad": "PD1", "type": "I/O/A",  "pins": [    7,       18,     15,    8 ]},
      {"pad": "PD2", "type": "I/O/A",  "pins": [ null,       19,     16, null ]},
      {"pad": "PD3", "type": "I/O/A",  "pins": [ null,       20,     17, null ]}
    ],

    // 2.2 TYPES
    // ---------
    // This section explains what the "type" field means that was given in the matrix above for each
    // pad/pin. Also, it lists for each configurable pad type what the compatible pad/pin modes are.
    // The naming of these types can differ from one MCU to another. For example, a 5V tolerant
    // digital input-output pin would be of type "I/O/FT" for the CH32V003 MCUs and of type "I/O_5T"
    // for APM32F411 MCUs.
    "types": {
      "I/O/A": {
        "description": "digital input-output or analog input",
        "mode": [ "FI", "PU", "PD", "PP", "OD", "PP-AF", "OD-AF", "AI" ],
        "kind": "io",
        "5v-tolerant": false
      },
      "I/O": {
        "description": "digital input-output",
        "mode": [ "FI", "PU", "PD", "PP", "OD", "PP-AF", "OD-AF" ],
        "kind": "io",
        "5v-tolerant": false
      },
      "I/O/FT": {
        "description": "digital input-output, 5V tolerant",
        "mode": [ "FI", "PU", "PD", "PP", "OD", "PP-AF", "OD-AF" ],
        "kind": "io",
        "5v-tolerant": true
      },
      "P": {
        "description": "power or ground pin",
        "kind": "power",
        "5v-tolerant": true
      }
    },

    // 2.3 MODE
    // ---------
    // Each pad/pin can operate in one of the modes listed below. This section is not intended to be
    // modified. If the MCU has a pad/pin mode not listed below, please contact us.
    // TODO: Check if mode below is unchanged.
    "mode": {
      "FI"   : {"description": "floating input"},
      "PU"   : {"description": "pull-up"},
      "PD"   : {"description": "pull-down"},
      "PP"   : {"description": "push-pull"},
      "OD"   : {"description": "open drain"},
      "AI"   : {"description": "analog input"}
    },

    // 2.4 OUTPUT_DRIVE
    // -----------------
    // The time it takes for a pad/pin to switch low-to-high or high-to-low is called the 'rise' and
    // 'fall' time. The rise and fall times depends on the pad/pin's drive current and its capa-
    // citive load on the board.
    // Most MCUs allow to select the output drive behavior. Some call it "output speed", others
    // "drive strength":
    //
    //     - "output speed":   Geehy, STMicro and WCH let you choose between "low", "medium", "fast"
    //                         and sometimes also "high" speed. Some specify the speed in MHz as
    //                         well.
    //
    //     - "drive strength": Texas Instruments and Microchip let you choose the drive strength per
    //                         pin, sometimes specified in mA.
    //
    // Define in the table below the output drive options (speed and/or drive strength) that appear
    // in the datasheet. Further down, the CONFIG section specifies the bitfield expressions to
    // achieve the output drive options defined here.
    // TODO: Interpret values below. Currently these values are ignored.
    "output_drive": {
        "LS": {"description": "low speed",    "speed": "2 MHz",  "drive-current": null},
        "MS": {"description": "medium speed", "speed": "10 MHz", "drive-current": null},
        "FS": {"description": "fast speed",   "speed": "30 MHz", "drive-current": null}
    },

    // 2.5 CONFIG
    // ----------
    // The "mode" and "output_drive" options defined above can be configured per pad/pin by setting
    // certain bitfields. This CONFIG section specifies how.
    "config": {
      // If there are any pads/pins that have no pad-name (eg. "NRST", "BOOT0", ...) specify their
      // "mode" and/or "output_drive" options here.
      

      // Specify the "mode" and "output_drive" options for all the pads/pins in a parametrized way.
      "P{x}{y}": {
        // PARAMETERS
        "parameters": {
          "x": [ "A", "C", "D" ],
          "y": [ "0", "1", "2", "3", "4", "5", "6", "7" ]
        },

        // ENABLE
        // Some MCUs let you enable/disable an entire port. For example: if you enable/disable port
        // PA, that would affect all pads PA0, PA1, ... Provide a bitfield expression here to
        // enable/disable Port x, if applicable. If there's no such enable/disable option, just fill
        // in "1" or true, which signifies that all pads are always enabled.
        "enable": "IOP{x}EN",

        // MODE
        // Specify the bitfields that define the "mode" of pad P{x}y.
        "mode": {
          "GPIO{x}.MODE{y}": {
            "00": [ "AI", "FI", "PD", "PU" ]
          },
          "GPIO{x}.CNF{y}": {
            "00": [ "AI", "PP" ],
            "01": [ "FI", "OD" ],
            "10": [ "PD", "PU", "PP-AF" ],
            "11": [ "OD-AF" ]
          },
          "GPIO{x}.ODR{y}": {
            "0": [ "PD" ],
            "1": [ "PU" ]
          }
        },

        // OUTPUT_DRIVE
        // Specify the bitfields that define the "output_drive" of pad Pxy.
        // TODO: Interpret this block. Currently ignored.
        "output_drive": {
            "GPIO{x}.MODE{y}": {
                "01": "MS",
                "10": "LS",
                "11": "FS"
            }
        },

        // MAP_SELECTOR
        "map_selector": null,

        // OTHER SETTINGS
        // TODO: Remove this block, will be replaced by previous.
        "settings": {
          "output_speed": {
            "description": "Maximum output speed",
            "only_for_mode": [ "PP", "OD", "PP-AF", "OD-AF" ],
            "selector": "GPIO{x}.MODE{y}",
            "values": {
              "0b01": "maximum speed 10 MHz",
              "0b10": "maximum speed 2 MHz",
              "0b11": "maximum speed 30 MHz"
            }
          }
        }
      }
    }
  },

  //----------------------------------------------------------------------------------------------//
  //                                        CLOCK SETTINGS                                        //
  //----------------------------------------------------------------------------------------------//
  // All settings related to the CLOCK VIEW in Embeetle
  "clock-tree": {
    // Peripheral name to use for the clock tree. Defaults to the first SVD peripheral name.
    "name": "RCC",
  
    // SVD peripherals to scan for register and bit field names
    "svd-peripherals": [ "RCC" ],
  
    "clocks": {
      "HSI": {
        "description": "internal high-frequency RC oscillator",
        "kind": "internal",
        "freq": "24MHz",
        "enable": "HSION",
        "ready": "HSIRDY",
        "settings": {
          "HSITRIM": {
            "label": "Internal high-speed clock adjust",
            "description": "Internal high-speed clock adjustment value. The user can enter an adjustment value to superimpose on the HSICAL[7:0] value to adjust the frequency of the internal HSI RC oscillator based on voltage and temperature variations. The default value is 16, which can adjust the HSI to 24MHz ±1%; the change of HSICAL is adjusted about 60KHz per step."
          }
        }
      },
      "LSI": {
        "description": "internal low-frequency RC oscillator",
        "kind": "internal",
        "freq": "128kHz",
        "enable": "LSION",
        "ready": "LSIRDY",
        "targets": [ "GPIO", "IWDG", "PWR" ]
      },
      "HSE": {
        "description": "external high-frequency crystal oscillator",
        "kind": "external",
        "xin": "OSC_IN",
        "xout": "OSC_OUT",
        "min_freq": "4MHz",
        "max_freq": "25MHz",
        "enable": "HSEON",
        "ready": "HSERDY",
        "bypass": "HSEBYP",
        "settings": {
          "CSSON": {
            "label": "Clock security system",
            "description": "When the clock security system is enabled and HSE is ready (HSERDY set to 1), the hardware turns on the clock monitoring function of HSE and triggers CSSF flag and NMI interrupt when HSE is found to be abnormal; when HSE is not ready, the hardware turns off the clock monitoring function of HSE."
          },
          "HSEBYP": {
            "label": "Bypass high-speed resonator",
            "description": "Bypass external high-speed crystal/ceramic resonators (using an external clock source).",
            "comment": "Needs to be written with HSEON at 0"
          }
        }
      },
      "PLLSRC": {
        "description": "input clock for PLL",
        "kind": "mux",
        "selector": "PLLSRC",
        "inputs": [ "HSI", "HSE" ]
      },
      "PLLCLK": {
        "description": "internal PLL double frequency clock",
        "kind": "multiplier",
        "input": "PLLSRC",
        "enable": "PLLON",
        "ready": "PLLRDY",
        "value": 2
      },
      "SYSCLK": {
        "description": "system clock",
        "kind": "mux",
        "selector-comment": "Should be: CSSF ? 0 : SW",
        "selector": "SW",
        "inputs": [ "HSI", "HSE", "PLLCLK" ],
        "status": "SWS"
      },
      "MCO": {
        "description": "microcontroller MCO pin output clock",
        "kind": "mux",
        "selector": "MCO[1:0]",
        "inputs": [ "SYSCLK", "HSI", "HSE", "PLLCLK"]
      },
      "HBCLK": {
        "description": "HB bus peripheral clock",
        "kind": "divider",
        "input": "SYSCLK",
        "selector": "HPRE",
        "dividers": [ 1, 2, 3, 4, 5, 6, 7, 8, 2, 4, 8, 16, 32, 64, 128, 256]
      }
    }
  },
  "busses": [
    {
      "name": "HB",
      "clock": "HBCLK"
    }
  ],
  "peripherals": {
    "GPIO": {
      "scope": [ "GPIOA", "GPIOB", "GPIOC", "GPIOD", "GPIOE", "GPIOH" ],
      "bus": "HB",
      "custom-signal-modes": [ "FI", "PU", "PD", "PP", "OD" ]
    },
    "RCC": {
      "signals": {
        "MCO": {
          "description": "Clock output",
          "enable": "MCO[2]",
          "map": "PC4",
          "mode": "PP"
        },
        "OSC_IN": {
          "description": "crystal+ or external clock",
          "enable": "HSEON & PA12_RM",
          "map": "PA1",
          "mode": "FI"
        },
        "OSC_OUT": {
          "description": "crystal-",
          "enable": "HSEON & PA12_RM & ~HSEBYP",
          "map": "PA2",
          "mode": "FI"
        }
      }
    },
    "PWR": {
      "enable": "PWREN",
      "settings": [
        {
          "label": "Power supply threshold",
          "description": "PVD voltage monitoring threshold setting. See the Electrical Characteristics section of the datasheet for detailed instructions.",
          "selector": "PLS",
          "values": {
            "0b000": "2.85V rising/2.7V falling",
            "0b001": "3.05V rising/2.9V falling",
            "0b010": "3.3V rising/3.15V falling",
            "0b011": "3.5V rising/3.3V falling",
            "0b100": "3.7V rising/3.5V falling",
            "0b101": "3.9V rising/3.7V falling",
            "0b110": "4.1V rising/3.9V falling",
            "0b111": "4.4V rising/4.2V falling"
          }
        },
        {
          "label": "Power supply monitoring enable",
          "description": "Power supply voltage monitoring",
          "selector": "PVDE"
        },
        {
          "label": "Power-down deep sleep mode",
          "description": "Standby/Sleep mode selection bit in power-down deep sleep scenario.",
          "selector": "PDDS",
          "values": {
            "1": "Enter Standby mode.",
            "0": "Enter Sleep mode."
          }
        },
        {
          "label": "AWU window value",
          "description": "AWU window value: The AWU window value is equal to the input value of the AWU window value + 1; The AWU window value is used to compare with the up counter value. When the counter value is equal to the window value, a wake-up signal is generated.",
          "selector": "AWUWR"
        },
        {
          "description": "Counting time base",
          "selector": "AWUPSC",
          "values": {
            "0b0000": "Prescaler off.",
            "0b0001": "Prescaler off.",
            "0b0010": "Divided by 2.",
            "0b0011": "Divided by 4.",
            "0b0100": "Divided by 8.",
            "0b0101": "Divided by 16.",
            "0b0110": "Divided by 32.",
            "0b0111": "Divided by 64.",
            "0b1000": "Divided by 128.",
            "0b1001": "Divided by 256.",
            "0b1010": "Divided by 512.",
            "0b1011": "Divided by 1024.",
            "0b1100": "Divided by 2048.",
            "0b1101": "Divided by 4096.",
            "0b1110": "Divided by 10240.",
            "0b1111": "Divided by 61440."
          }
        }
      ]
    },
    "SYS": {
      "signals": {
        "NRST": {
          "description": "Reset pin, active low",
          "enable": "RST_MODE != 0b11",
          "map": "PD7",
          "mode": "FI"
        }
      },
      "settings": {
        "RST_MODE": {
          "label": "Reset pni activation delay",
          "description": "Activation delay for reset pin NRST/PD7",
          "values": {
            "0b00": "128us",
            "0b01": "1ms",
            "0b10": "12ms"
          },
          "reset_value": "10"
        }
      }
    },
    "AFIO": {
      "enable": "AFIOEN"
    },
    "EXTEN": {
    },
    "EXTI": {
      "description": "External interrupt"
    },
    "DMA1": {
    },
    "IWDG": {
    },
    "WWDG": {
      "enable": "WWDGEN"
    },
    "TIM1": {
      "description": "Advanced-control timer (ADTM)",
      "enable": "TIM1EN",
      "signals": {
        "ETR": {
          "description": "Externally triggered clock input",
          "mode": "FI",
          "enable": "TS == 0b111 && SMS[2] == 1"
        },
        "CH{x}": {
          "description": "Input capture channel or output comparison channel",
          "parameters": { "x": [ "1", "2", "3", "4" ] },
          "mode": {
            "CC{x}S == 0b00": "PP",
            "CC{x}S != 0b00": "FI"
          },
          "enable": "(CC{x}E || CC{x}S != 0b00) && ({x} != 1 || !TIM1_1_RM)"
        },
        "CH{x}N": {
          "description": "Complementary comparison capture channel",
          "parameters": { "x": [ "1", "2", "3" ] },
          "mode": "PP",
          "enable": "CC{x}NE"
        },
        "BKIN": {
          "description": "Brake input",
          "mode": "FI",
          "enable": "BKE"
        }
      },
      "map": {
        "TIM1_RM": {
          "ETR":  [ "PC5", "PC5", "PD4", "PC2" ],
          "CH1":  [ "PD2", "PC6", "PD2", "PC4" ],
          "CH2":  [ "PA1", "PC7", "PA1", "PC7" ],
          "CH3":  [ "PC3", "PC0", "PC3", "PC5" ],
          "CH4":  [ "PC4", "PD3", "PC4", "PD4" ],
          "BKIN": [ "PC2", "PC1", "PC2", "PC1" ],
          "CH1N": [ "PD0", "PC3", "PD0", "PC3" ],
          "CH2N": [ "PA2", "PC4", "PA2", "PD2" ],
          "CH3N": [ "PD1", "PD1", "PD1", "PC6" ]
        }
      }
    },
    "TIM2": {
      "description": "General purpose timer (GPTM)",
      "enable": "TIM2EN",
      "signals": {
        "ETR": {
          "description": "Externally triggered clock input",
          "mode": "FI",
          "enable": "TS == 0b111 && SMS[2] == 1"
        },
        "CH{x}": {
          "description": "Input capture channel or output comparison channel",
          "parameters": { "x": [ "1", "2", "3", "4" ] },
          "mode": {
            "CC{x}S == 0b00": "PP",
            "CC{x}S != 0b00": "FI"
          },
          "enable": "CC{x}E || CC{x}S != 0b00"
        }
      },
      "map": {
        "TIM2_RM": {
          "ETR": [ "PD4", "PC5", "PC1", "PC1" ],
          "CH1": [ "PD4", "PC5", "PC1", "PC1" ],
          "CH2": [ "PD3", "PC2", "PD3", "PC7" ],
          "CH3": [ "PC0", "PD2", "PC0", "PD6" ],
          "CH4": [ "PD7", "PC1", "PD7", "PD5" ]
        }
      }
    },
    "I2C1": {
      "enable": "I2C1EN",
      "signals": {
        "SCL": {
          "description": "I2C clock",
          "mode": "OD"
        },
        "SDA": {
          "description": "I2C data",
          "mode": "OD"
        }
      },
      "settings": {
        
      },
      "map": {
        "I2C1REMAP1:I2C1_RM": {
          "SCL": [ "PC2", "PD1", "PC5", "PC5" ],
          "SDA": [ "PC1", "PD0", "PC6", "PC6" ]
        }
      }
    },
    "SPI1": {
      "description": "Serial peripheral interface",
      "enable-comment": "set SPI1EN before configuring, SPE after configuring",
      "enable": "SPI1EN && SPE",
      "signals": {
        "SCK": {
          "description": "SPI clock",
          "mode": {
            "MSTR": "PP",
            "!MSTR": "FI"
          }
        },
        "MOSI": {
          "description": "SPI master-out slave-in",
          "mode-comment": {
            "full-duplex master": "PP",
            "full-duplex slave": [ "FI", "PU" ],
            "simple bi-directional data line master": "PP",
            "simple bi-directional data line slave": null
          },
          "mode": {
            "!BIDIMODE && MSTR": "PP",
            "!BIDIMODE && !MSTR": [ "FI", "PU" ],
            "BIDIMODE && MSTR": "PP"
          }
        },
        "MISO": {
          "description": "SPI master-in slave-out",
          "mode-comment": {
            "full-duplex master": [ "FI", "PU" ],
            "full-duplex slave": "PP",
            "simple bi-directional data line master": null,
            "simple bi-directional data line slave": "PP"
          },
          "mode": {
            "!BIDIMODE && MSTR": "PP",
            "!BIDIMODE && !MSTR": [ "FI", "PU" ],
            "BIDIMODE && !MSTR": "PP"
          }
        },
        "NSS": {
          "description": "SPI slave select",
          "comment-1": "SSM=1 means NSS is controlled by software",
          "comment-2": "SSOE means NSS is not used (replaced by gpio pad)",
          "mode": "PP",
          "enable": "SSOE"
        }
      },
      "map": {
        "SPI1_RM": {
          "NSS": [ "PC1", "PC0" ],
          "SCK": [ "PC5", "PC5" ],
          "MISO": [ "PC7", "PC7" ],
          "MOSI": [ "PC6", "PC6" ]
        }
      },
      "settings": [
        {
          "description": "Master/slave mode",
          "selector": "MSTR",
          "values": {
            "0": "Configured as slave device",
            "1": "Configured as master device"
          }
        },
        {
          "description": "Data mode",
          "selector": "BIDIMODE : BIDIOE : RXONLY",
          "values": {
            "0b010": "Full duplex",
            "0b110": "Half duplex",
            "0b110": "Send only",
            "0b101": "Receive only"
          }
        },
        {
          "description": "Slave select mode",
          "selector": "SSOE : SSM",
          "values": {
            "0b10": "NSS driven by hardware",
            "0b11": "NSS driven by software via SSI",
            "0b0x": "NSS not used"
          },
          "predicate": "MSTR == 1"
        },
        {
          "label": "Hardware CRC checksum",
          "description": "Use hardware CRC checksum (full duplex mode only)",
          "selector": "CRCEN",
          "predicate": "BIDIMODE == 0"
        },
        {
          "description": "Data frame size",
          "selector": "DFF",
          "values": {
            "0": "16 bit data",
            "1": "8 bit data"
          }
        },
        {
          "description": "Data frame format",
          "selector": "LSBFIRST",
          "values": {
            "0": "MSB transmitted first",
            "1": "LSB transmitted first"
          },
          "predicate": "MSTR == 1"
        }
      ]
    },
    "USART1": {
      "enable": "USART1EN && !UE",
      "signals": {
        "CK": {
          "description": "USART clock",
          "enable": "CLKEN",
          "mode": "PP"
        },
        "TX": {
          "description": "USART data transmit",
          "enable": "TE",
          "mode-comment": {
            "desc-comment": "HDSEL = half duplex mode",
            "full-duplex": "PP",
            "half-duplex synchronous": "OD"
          },
          "mode": {
            "HDSEL == 0": "PP",
            "HDSEL == 1 && CLKEN": "OD"
          }
        },
        "RX": {
          "description": "USART data receive",
          "enable": "RE",
          "mode-comment": {
            "full-duplex": [ "FI", "PU" ]
          },
          "mode": {
            "HDSEL == 0": [ "FI", "PU" ]
          }
        },
        "CTS": {
          "description": "USART clear to send",
          "enable": "CTSE",
          "mode-comment": {
            "hardware flow control": [ "FI", "PU" ]
          },
          "mode": [ "FI", "PU" ]
        },
        "RTS": {
          "description": "USART request to send",
          "enable": "RTSE",
          "mode-comment": {
            "hardware flow control": "PP"
          },
          "mode": "PP"
        }
      },
      "map": {
        "USART1REMAP1:USART1_RM": {
          "CK": [ "PD4", "PD7", "PD7", "PD5" ],
          "TX": [ "PD5", "PD0", "PD6", "PC0" ],
          "RX": [ "PD6", "PD1", "PD5", "PC1" ],
          "CTS": [ "PD3", "PC3", "PC6", "PC6" ],
          "RTS": [ "PC2", "PC2", "PC7", "PC7" ]
        }
      },
      "enable": "UE"
    },
    "ADC1": {
      "enable": "ADC1EN",
      "clock": {
        "description": "ADC conversion clock",
        "kind": "divider",
        "input": "HBCLK",
        "selector": "ADCPRE",
        "dividers": [ 2, 2, 2, 2, 4, 8, 16, 32, 4, 4, 4, 4, 8, 16, 32, 64,
                      6, 6, 6, 6, 12, 24, 48, 96, 8, 8, 8, 8, 16, 32, 64, 128
                    ]
      },
      "signals": {
        "A{i}": {
          "parameters": { "i": [ "0", "1", "2", "3", "4", "5", "6", "7" ] },
          "description": "Analog input",
          "mode": "AI",
          "used-comment": "Expression not interpreted yet",
          "used": "any(SQj == {i} for j in 1..L+1) or any(JSQj == {i} for j in 1..JL+1)",
          "map": [ "PA2", "PA1", "PC4", "PD2", "PD3", "PD5", "PD6", "PD4" ]
        },
        "AETR": {
          "description": "ADC external trigger for rule conversion",
          "enable": "EXTTRIG & EXTSEL==0b110",
          "mode": [ "FI", "PU", "PD" ]
        },
        "AETR2": {
          "description": "ADC external trigger for injection conversion",
          "enable": "JEXTTRIG & JEXTSEL==0b110",
          "mode": [ "FI", "PU", "PD" ]
        }
      },
      "map": {
        "ADC1_ETRGREG_RM": { "AETR": [ "PD3", "PC2" ] },
        "ADC1_ETRGINJ_RM": { "AETR2": [ "PD1", "PA2" ] }
      }
    },
    "OPA": {
      "description": "operational amplifier",
      "enable": "OPAEN",
      "signals": {
        "P": {
          "description": "operational amplifier positive input",
          "mode": "FI"
        },
        "N": {
          "description": "operational amplifier negative input",
          "mode": "FI"
        },
        "O": {
          "description": "operational amplifier output",
          "mode": "FI",
          "map": "PD4"
        }
      },
      "map": {
        "OPAPSEL": { "P": [ "PA2", "PD7" ] },
        "OPANSEL": { "N": [ "PA1", "PD0" ] }
      }
    },
    "DBG": {
    },
    "ESIG": {
    },
    "FLASH": {
    },
    "PFIC": {
    }
  },
